# Auth DB (new — สร้าง DB ourkk ใน Postgres ก่อน)
AUTH_DATABASE_URL=postgres://postgres:password@postgres:5432/ourkk

# Solar/MEA DB (aide-collector)
DATABASE_URL=postgres://postgres:password@postgres:5432/collector
SOLAR_DEVICE_ID=                    # query: SELECT DISTINCT device_id FROM stash.solar_record
MEA_HOUSE_CA=                       # query: SELECT ca, alias FROM stash.mea_meter

# better-auth
BETTER_AUTH_SECRET=                 # bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Access control (comma-separated emails)
ALLOWED_EMAILS=

# App
APP_BASE_URL=http://localhost:4321

# Socket.io
SOCKET_PORT=3000

# Logging: LOG_FORMAT=text (pino-pretty) | json (raw, default prod)
LOG_LEVEL=info
LOG_FORMAT=text
