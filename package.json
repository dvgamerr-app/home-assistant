{
  "name": "home-assistant",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun x --bun astro dev",
    "dev:socket": "bun server/socket.mjs",
    "dev:all": "bun run dev & bun run dev:socket",
    "build": "bun x --bun astro build",
    "preview": "bun ./dist/server/entry.mjs",
    "check": "bun x --bun astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migration:run": "bun src/db/migrate.ts",
    "prepare": "husky",
    "test": "bun x lint-staged && bun x commitlint --last --verbose"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,svelte,astro,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,ts,mjs,svelte,astro}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.20",
    "@lucide/svelte": "^1.21.0",
    "@nurodev/astro-bun": "^2.1.2",
    "better-auth": "^1.6.20",
    "charts.css": "^1.2.0",
    "kysely": "^0.29.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/svelte": "^7.2.3",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.1.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.8",
    "@types/pg": "^8.20.0",
    "astro": "^5.16.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "pg": "^8.22.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.4.1",
    "socket.io-client": "^4.8.3",
    "svelte": "^5.49.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.46.0"
  }
}
