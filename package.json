{
  "name": "home-assistant",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun x --bun astro dev",
    "dev:socket": "bun server/socket.mjs",
    "build": "bun x --bun astro build",
    "preview": "bun ./dist/server/entry.mjs",
    "check": "bun x --bun astro check",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "migration:run": "bun src/db/migrate.ts",
    "prepare": "husky",
    "test": "bun test"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,svelte,astro,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,ts,mjs,svelte,astro}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@astrojs/node": "^11.0.1",
    "@better-auth/kysely-adapter": "^1.6.23",
    "@lucide/svelte": "^1.23.0",
    "better-auth": "^1.6.23",
    "kysely": "^0.29.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^9.0.1",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "astro": "^7.0.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pg": "^8.22.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
