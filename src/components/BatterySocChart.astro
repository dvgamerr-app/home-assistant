---
import { lineScale } from '@/lib/chart'
import type { SolarData } from '@/lib/solar-data'

const { hourlySoc: HOURLY_SOC } = Astro.props as Pick<SolarData, 'hourlySoc'>
const soc = lineScale(
  HOURLY_SOC.map((r) => r.soc),
  100,
)
---

<section class="rounded-lg border border-border/70 bg-card p-6">
  <div class="mb-6">
    <h2 class="font-serif text-lg font-light text-foreground">ระดับแบตเตอรี่ระหว่างวัน</h2>
    <p class="mt-1 text-sm leading-relaxed text-muted-foreground">แบตชาร์จขึ้นช่วงกลางวันที่แดดแรง และค่อย ๆ จ่ายไฟให้บ้านในช่วงเย็นถึงกลางคืน · ต่ำกว่า 20% ถือว่าเหลือน้อย</p>
  </div>

  <div class="chart-frame">
    <table class="charts-css line show-4-secondary-axes" style="--color-1:var(--chart-1)">
      <tbody>
        {
          HOURLY_SOC.map((r, i) => (
            <tr>
              <td style={`--start:${soc[i].start};--end:${soc[i].end}`}>
                <span class="data">{r.soc}%</span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-5 flex flex-wrap gap-x-6 text-xs text-muted-foreground">
    <span class="flex items-center gap-2"><span class="legend-dot" style="background:var(--chart-1)"></span>ระดับแบตเตอรี่ (%)</span>
    <span class="ml-auto">00:00 → 23:00</span>
  </div>
</section>
