---
import Sun from '@lucide/svelte/icons/sun'
import Plug from '@lucide/svelte/icons/plug'
import PiggyBank from '@lucide/svelte/icons/piggy-bank'
import Gauge from '@lucide/svelte/icons/gauge'
import StatCard from './StatCard.astro'
import ChartCard from './ui/ChartCard.astro'
import LegendRow from './ui/LegendRow.astro'
import { svgStackedBars } from '@/lib/chart'
import { thb, num } from '@/lib/electricity'
import type { MonthLoad } from '@/lib/solar-data'

interface Props {
  today: { generated: number; consumed: number; gridImport: number; generationHours: number }
  day: { selfUse: number; savedTHB: number; gridCostTHB: number; wouldHaveCostTHB: number; selfSufficiency: number }
  monthDays: Array<{ day: string; selfUse: number; gridImport: number; generated: number; consumed: number; saved: number }>
  monthLabel: string
  isCurrentMonth?: boolean
  selMonthTotals?: MonthLoad['totals']
  prevMonthSummary?: MonthLoad
  availableMonths?: Array<{ value: string; label: string }>
  selectedMonth?: string
}

const { today: TODAY, day: DAY, monthDays: MONTH_DAYS, monthLabel, isCurrentMonth = true, selMonthTotals, prevMonthSummary, availableMonths, selectedMonth } = Astro.props

// สถิติสำหรับ stat cards — today สำหรับเดือนปัจจุบัน, สรุปรวมสำหรับเดือนที่ผ่านมา
const S = isCurrentMonth
  ? {
      generated: TODAY.generated,
      consumed: TODAY.consumed,
      gridImport: TODAY.gridImport,
      selfUse: DAY.selfUse,
      savedTHB: DAY.savedTHB,
      gridCostTHB: DAY.gridCostTHB,
      wouldHaveCostTHB: DAY.wouldHaveCostTHB,
      selfSufficiency: DAY.selfSufficiency,
      generationHours: TODAY.generationHours,
    }
  : { ...selMonthTotals!, generationHours: undefined }
const period = isCurrentMonth ? 'วันนี้' : 'เดือนรวม'

// SVG stacked bar: [gridImport, selfUse] per day — grid อยู่ล่าง
const VW = 560,
  VH = 280,
  ML = 4,
  MT = 8,
  MR = 8,
  MB = 24
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const ph = py1 - py0

const maxTotal = Math.max(...MONTH_DAYS.map((d) => d.selfUse + d.gridImport), 1)

const bars = svgStackedBars(
  MONTH_DAYS.map((d) => [d.gridImport, d.selfUse]),
  px0,
  py0,
  px1,
  py1,
  0.15,
)

const gridLines = [0.25, 0.5, 0.75, 1].map((f) => ({
  y: +(py0 + (1 - f) * ph).toFixed(1),
  label: num(+(f * maxTotal).toFixed(1), 1),
  isMax: f === 1,
}))

const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)

const segColors = ['var(--chart-4)', 'var(--chart-1)']
const segOpacity = [0.35, 0.85]
---

<div class="space-y-6">
  <!-- Stat cards -->
  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    <StatCard
      label={`ผลิตไฟ${period}`}
      value={`${num(S.generated, 1)} kWh`}
      sub={S.generationHours !== undefined ? `ผลิตมาแล้ว ${num(S.generationHours, 1)} ชม.` : `ใช้เองในบ้าน ${num(S.selfUse, 1)} kWh`}
      accent="brass"
    >
      <Sun slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label={`ใช้ไฟ${period}`} value={`${num(S.consumed, 1)} kWh`} sub={`ใช้จากแสงอาทิตย์ ${num(S.selfUse, 1)} kWh`} accent="blue">
      <Plug slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label={`ประหยัด${period}`} value={thb(S.savedTHB, 0)} sub={`ถ้าไม่มีโซลาร์จ่าย ${thb(S.wouldHaveCostTHB, 0)}`} trend={`${num(S.selfSufficiency, 0)}% พึ่งตัวเอง`} accent="sage">
      <PiggyBank slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label={`ค่าไฟจากกริด${period}`} value={thb(S.gridCostTHB, 0)} sub={`ซื้อจากการไฟฟ้า ${num(S.gridImport, 1)} kWh`} accent="terracotta">
      <Gauge slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
  </div>

  <!-- Bar chart -->
  <ChartCard title="ไฟที่ใช้แต่ละวัน — จากโซลาร์ เทียบกับ ซื้อ" subtitle={`เดือน${monthLabel} · หน่วยเป็น kWh ต่อวัน`}>
    {
      availableMonths && availableMonths.length > 0 && (
        <label slot="header-action" class="relative inline-flex items-center">
          <select
            onchange="location.href='?m='+this.value"
            class="min-w-28 cursor-pointer appearance-none rounded border border-border/60 bg-card py-1.5 pl-3 pr-7 text-[10px] uppercase tracking-luxury text-muted-foreground outline-none transition-colors hover:border-foreground/30 hover:text-foreground focus:border-foreground/30 focus:text-foreground"
          >
            {availableMonths.map((m) => (
              <option value={m.value} selected={m.value === selectedMonth}>
                {m.label}
              </option>
            ))}
          </select>
          <svg
            class="pointer-events-none absolute right-2 text-muted-foreground"
            width="10"
            height="10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap={'round' as const}
            stroke-linejoin={'round' as const}
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </label>
      )
    }
    <div class="flex items-start gap-1">
      <div class="relative shrink-0 overflow-visible" style="width:1.75rem;height:280px">
        {
          gridLines.map((g) => (
            <span
              class:list={['absolute right-0 text-right text-[9px] leading-none', g.isMax ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
              style={`top:${((g.y / VH) * 100).toFixed(2)}%;transform:translateY(-50%)`}
            >
              {g.label}
            </span>
          ))
        }
      </div>
      <div class="min-w-0 flex-1">
        <div class="chart-frame">
          <svg class="daily-chart-svg" viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
            {gridLines.map((g) => <line x1={px0} x2={px1} y1={g.y} y2={g.y} stroke="var(--border)" stroke-opacity={g.isMax ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
            {bars.map((segs) => segs.map((seg, j) => (seg.h > 0 ? <rect x={seg.x} y={seg.y} width={seg.w} height={seg.h} rx={seg.rx} fill={segColors[j]} fill-opacity={segOpacity[j]} /> : null)))}
            <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.5" stroke-width="0.5"></line>
            <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.5" stroke-width="0.5"></line>
            {
              bars.map((segs, i) => (
                <rect
                  class="bar-hit"
                  x={segs[0].x}
                  y={py0}
                  width={segs[0].w}
                  height={ph}
                  fill="transparent"
                  data-day={MONTH_DAYS[i].day}
                  data-solar={num(MONTH_DAYS[i].selfUse, 1)}
                  data-grid={num(MONTH_DAYS[i].gridImport, 1)}
                  data-total={num(MONTH_DAYS[i].selfUse + MONTH_DAYS[i].gridImport, 1)}
                  style="cursor:crosshair"
                />
              ))
            }
          </svg>
        </div>
        <div class="mt-1 grid text-[9px] text-muted-foreground" style={`grid-template-columns:repeat(${MONTH_DAYS.length},1fr);padding-left:${padLeft}%;padding-right:${padRight}%`}>
          {MONTH_DAYS.map((d) => <span class="truncate text-center">{d.day}</span>)}
        </div>
      </div>
    </div>

    <LegendRow
      class="mt-5"
      items={[
        { label: 'ใช้ไฟจากโซลาร์', color: 'var(--chart-1)' },
        { label: 'ซื้อจากการไฟฟ้า', color: 'color-mix(in oklch, var(--chart-4) 40%, transparent)' },
      ]}
    />
  </ChartCard>

  <!-- Tooltip -->
  <div class="daily-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:140px;transition:opacity 0.1s">
    <p class="tip-day mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
    <div class="space-y-1.5">
      <div class="flex items-center justify-between gap-4">
        <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
          <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-1)"></span>โซลาร์
        </span>
        <span class="tip-solar font-mono text-[11px] text-foreground"></span>
      </div>
      <div class="flex items-center justify-between gap-4">
        <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
          <span class="h-2 w-2 shrink-0 rounded-full" style="background:color-mix(in oklch,var(--chart-4) 50%,transparent)"></span>กริด
        </span>
        <span class="tip-grid font-mono text-[11px] text-foreground"></span>
      </div>
      <div class="flex items-center justify-between gap-4 border-t border-border/50 pt-1.5">
        <span class="text-[11px] text-muted-foreground">รวม</span>
        <span class="tip-total font-mono text-[11px] font-medium text-foreground"></span>
      </div>
    </div>
  </div>

  <!-- Previous month summary -->
  {
    prevMonthSummary && (
      <section class="rounded-lg border border-border/70 bg-card px-6 py-5">
        <div class="mb-5 flex items-baseline gap-2">
          <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">สรุปเดือนก่อนหน้า</p>
          <span class="text-xs text-muted-foreground">· {prevMonthSummary.label}</span>
        </div>
        <div class="grid grid-cols-2 gap-x-8 gap-y-5 sm:grid-cols-4">
          <div>
            <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ผลิตได้</p>
            <p class="mt-1.5 font-serif text-2xl font-light text-foreground">{num(prevMonthSummary.totals.generated, 1)}</p>
            <p class="mt-0.5 text-xs text-muted-foreground">kWh</p>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ใช้ในบ้าน</p>
            <p class="mt-1.5 font-serif text-2xl font-light text-foreground">{num(prevMonthSummary.totals.consumed, 1)}</p>
            <p class="mt-0.5 text-xs text-muted-foreground">kWh</p>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ซื้อจากกริด</p>
            <p class="mt-1.5 font-serif text-2xl font-light text-foreground">{num(prevMonthSummary.totals.gridImport, 1)}</p>
            <p class="mt-0.5 text-xs text-muted-foreground">kWh</p>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ประหยัดได้</p>
            <p class="mt-1.5 font-serif text-2xl font-light text-chart-1">{thb(prevMonthSummary.totals.savedTHB, 0)}</p>
            <p class="mt-0.5 text-xs text-muted-foreground">เทียบไม่มีโซลาร์</p>
          </div>
        </div>
      </section>
    )
  }
</div>

<script>
  {
    const tip = document.querySelector<HTMLElement>('.daily-chart-tip')
    if (tip) {
      const dayEl = tip.querySelector('.tip-day')!
      const solarEl = tip.querySelector('.tip-solar')!
      const gridEl = tip.querySelector('.tip-grid')!
      const totalEl = tip.querySelector('.tip-total')!

      document.querySelectorAll<SVGRectElement>('.bar-hit').forEach((r) => {
        r.addEventListener('mouseenter', (e) => {
          const d = (e.currentTarget as SVGRectElement).dataset
          dayEl.textContent = 'วันที่ ' + d.day
          solarEl.textContent = d.solar + ' kWh'
          gridEl.textContent = d.grid + ' kWh'
          totalEl.textContent = d.total + ' kWh'
          tip.classList.remove('hidden')
        })
        r.addEventListener('mousemove', (e) => {
          const x = Math.min(e.clientX + 14, window.innerWidth - 160)
          const y = Math.max(e.clientY - 70, 8)
          tip.style.left = x + 'px'
          tip.style.top = y + 'px'
        })
        r.addEventListener('mouseleave', () => tip.classList.add('hidden'))
      })
    }
  }
</script>
