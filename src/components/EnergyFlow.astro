---
import Sun from '@lucide/svelte/icons/sun'
import Home from '@lucide/svelte/icons/house'
import BatteryCharging from '@lucide/svelte/icons/battery-charging'
import Zap from '@lucide/svelte/icons/zap'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'

const { live } = Astro.props as Pick<SolarData, 'live'>
const charging = live.batteryPowerKw < 0
const nodes = [
  { Icon: Sun, label: 'แผงโซลาร์', value: `${num(live.pvPowerKw, 2)} kW`, tone: 'text-chart-2' },
  { Icon: BatteryCharging, label: charging ? 'แบตเตอรี่ · กำลังชาร์จ' : 'แบตเตอรี่ · จ่ายไฟ', value: `${live.batterySoc}%`, tone: 'text-chart-1' },
  { Icon: Home, label: 'โหลดในบ้าน', value: `${num(live.loadPowerKw, 2)} kW`, tone: 'text-chart-3' },
  { Icon: Zap, label: 'การไฟฟ้า (กริด)', value: `${num(live.gridPowerKw, 2)} kW`, tone: 'text-muted-foreground' },
]
---

<section class="rounded-lg border border-border/70 bg-card p-6 md:p-8">
  <div class="mb-8 flex items-center justify-between">
    <h2 class="font-serif text-xl font-light text-foreground">การไหลของพลังงานตอนนี้</h2>
    <span class="flex items-center gap-2 text-[10px] uppercase tracking-luxury text-muted-foreground">
      <span class="size-1.5 animate-pulse rounded-full bg-chart-1"></span>
      เรียลไทม์
    </span>
  </div>

  <div class="grid grid-cols-2 gap-y-8 sm:grid-cols-4">
    {
      nodes.map(({ Icon, label, value, tone }) => (
        <div class="flex flex-col items-center gap-3 text-center">
          <span class={`flex size-12 items-center justify-center rounded-full border border-border/70 ${tone}`}>
            <Icon size={20} strokeWidth={1.25} />
          </span>
          <div class="space-y-1">
            <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">{label}</p>
            <p class="font-serif text-lg font-light text-foreground">{value}</p>
          </div>
        </div>
      ))
    }
  </div>

  <p class="mt-8 border-t border-border/60 pt-5 text-sm leading-relaxed text-muted-foreground">
    ตอนนี้แผงผลิตได้ <strong class="font-medium text-foreground">{num(live.pvPowerKw, 2)} kW</strong> บ้านใช้ไฟ
    <strong class="font-medium text-foreground">{num(live.loadPowerKw, 2)} kW</strong> พลังงานส่วนเกินกำลังชาร์จเข้าแบตเตอรี่ ({num(Math.abs(live.batteryPowerKw), 2)} kW) — ขณะนี้<strong
      class="font-medium text-foreground">ไม่ได้ซื้อไฟจากการไฟฟ้าเลย</strong
    >
  </p>
</section>
