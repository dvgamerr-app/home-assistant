---
import LiveClock from './LiveClock.svelte'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'
import Sun from '@lucide/svelte/icons/sun'
import Droplets from '@lucide/svelte/icons/droplets'
import Wind from '@lucide/svelte/icons/wind'

interface Props extends Pick<SolarData, 'live' | 'system'> {
  userName: string
}

const { live, userName } = Astro.props
const firstName = userName.split(' ')[0]
const charging = live.batteryPowerKw < 0
const buyingNothing = live.gridPowerKw < 0.05

// ponytail: static weather — wire to a real API when you have a key
const weather = { tempC: 22, humidity: 48, windKph: 6 }
---

<section class="border-b border-border/60 px-6 py-12 md:px-10 md:py-16">
  <div class="flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
    <div class="space-y-6">
      <p class="text-[11px] uppercase tracking-luxury text-muted-foreground">
        <LiveClock client:load />
      </p>
      <h1 class="text-balance font-serif text-5xl font-light leading-[1.05] md:text-6xl lg:text-7xl">
        ยินดีต้อนรับกลับบ้าน,<br />
        <span class="italic text-foreground/90">{firstName}</span>
      </h1>
      <p class="max-w-md text-pretty text-sm leading-relaxed text-muted-foreground">
        บ้านกำลังทำงานเป็นปกติ แผงโซลาร์ผลิตไฟอยู่ {num(live.pvPowerKw, 2)} กิโลวัตต์{charging ? ' และพลังงานส่วนเกินกำลังชาร์จเข้าแบตเตอรี่' : ''}{
          buyingNothing ? ' — ขณะนี้ไม่ได้ซื้อไฟจากการไฟฟ้าเลย' : ''
        }
      </p>
    </div>

    <dl class="grid grid-cols-3 gap-6 md:gap-10">
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2 text-muted-foreground">
          <Sun class="h-4 w-4" strokeWidth={1.25} aria-hidden="true" />
          <dt class="text-[10px] uppercase tracking-luxury">Outside</dt>
        </div>
        <dd class="font-serif text-3xl font-light text-foreground md:text-4xl">{weather.tempC}°</dd>
      </div>
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2 text-muted-foreground">
          <Droplets class="h-4 w-4" strokeWidth={1.25} aria-hidden="true" />
          <dt class="text-[10px] uppercase tracking-luxury">Humidity</dt>
        </div>
        <dd class="font-serif text-3xl font-light text-foreground md:text-4xl">{weather.humidity}%</dd>
      </div>
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2 text-muted-foreground">
          <Wind class="h-4 w-4" strokeWidth={1.25} aria-hidden="true" />
          <dt class="text-[10px] uppercase tracking-luxury">Breeze</dt>
        </div>
        <dd class="font-serif text-3xl font-light text-foreground md:text-4xl">{weather.windKph} km/h</dd>
      </div>
    </dl>
  </div>
</section>
