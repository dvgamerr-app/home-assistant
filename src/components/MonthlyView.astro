---
import Sun from '@lucide/svelte/icons/sun'
import Wallet from '@lucide/svelte/icons/wallet'
import PiggyBank from '@lucide/svelte/icons/piggy-bank'
import Leaf from '@lucide/svelte/icons/leaf'
import StatCard from './StatCard.astro'
import ChartCard from './ui/ChartCard.astro'
import LegendRow from './ui/LegendRow.astro'
import { svgLine, svgArea } from '@/lib/chart'
import { thb, num } from '@/lib/electricity'

interface MonthEntry {
  month: string
  generated: number
  consumed: number
  selfUse: number
  gridImport: number
  billWithSolar: number
  billWithoutSolar: number
  saved: number
}
interface Props {
  months: MonthEntry[]
  lifetime: { generated: number; gridImport: number; generationTime: number; co2ReductionKg: number }
}
const { months, lifetime: LIFETIME } = Astro.props
const current = months[months.length - 1] ?? { generated: 0, selfUse: 0, billWithSolar: 0, billWithoutSolar: 0, saved: 0, month: '' }
const annualSaving = months.reduce((s: number, m: MonthEntry) => s + m.saved, 0)

// ── SVG constants shared by both charts ─────────────────────────────────────
const VW = 560,
  VH = 280,
  ML = 8,
  MT = 12,
  MR = 8,
  MB = 4
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const pw = px1 - px0,
  ph = py1 - py0
const n = months.length

// ── Bill comparison: grouped bars (withoutSolar | withSolar) ─────────────────
const billMax = Math.max(...months.map((m: MonthEntry) => m.billWithoutSolar), 1)
const groupW = pw / n
const barGap = Math.max(1, groupW * 0.08)
const barW = (groupW - barGap * 3) / 2

const billBars = months.map((m: MonthEntry, i: number) => {
  const x = px0 + i * groupW + barGap
  const h1 = (m.billWithoutSolar / billMax) * ph
  const h2 = (m.billWithSolar / billMax) * ph
  return {
    b1: { x, y: py1 - h1, w: barW, h: h1, rx: 1.5 },
    b2: { x: x + barW + barGap, y: py1 - h2, w: barW, h: h2, rx: 1.5 },
  }
})

const billTicks = [1, 0.75, 0.5, 0.25]
const billGridYs = billTicks.map((f) => ({ y: +(py0 + (1 - f) * ph).toFixed(1), isMax: f === 1 }))
const billGridPct = billTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const billYLabels = billTicks.map((f) => thb(f * billMax, 0))

// ── Energy area: generated vs selfUse ────────────────────────────────────────
const energyMax = Math.max(...months.map((m: MonthEntry) => Math.max(m.generated, m.selfUse)), 1)
const genVals = months.map((m: MonthEntry) => m.generated / energyMax)
const selfVals = months.map((m: MonthEntry) => m.selfUse / energyMax)

const genLine = svgLine(genVals, px0, py0, px1, py1)
const genFill = svgArea(genVals, px0, py0, px1, py1)
const selfLine = svgLine(selfVals, px0, py0, px1, py1)
const selfFill = svgArea(selfVals, px0, py0, px1, py1)

const energyTicks = [1, 0.75, 0.5, 0.25]
const energyGridYs = energyTicks.map((f) => ({ y: +(py0 + (1 - f) * ph).toFixed(1), isMax: f === 1 }))
const energyGridPct = energyTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const energyYLabels = energyTicks.map((f) => num(f * energyMax, 0))

// month label alignment matching SVG margins
const labelPl = `${((ML / VW) * 100).toFixed(2)}%`
const labelPr = `${((MR / VW) * 100).toFixed(2)}%`
---

<div class="space-y-6">
  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    <StatCard label="ผลิตไฟเดือนนี้" value={`${num(current.generated, 0)} kWh`} sub={`ใช้เอง ${num(current.selfUse, 0)} kWh`} accent="brass">
      <Sun slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ค่าไฟเดือนนี้" value={thb(current.billWithSolar, 0)} sub={`ถ้าไม่มีโซลาร์ ${thb(current.billWithoutSolar, 0)}`} accent="terracotta">
      <Wallet slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ประหยัดเดือนนี้" value={thb(current.saved, 0)} sub={`รวมทั้งปี ~${thb(annualSaving, 0)}`} accent="sage" trend={`${num((current.saved / current.billWithoutSolar) * 100, 0)}%`}>
      <PiggyBank slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ลด CO₂ สะสม" value={`${num(LIFETIME.co2ReductionKg, 0)} kg`} sub="เทียบเท่าปลูกต้นไม้หลายสิบต้น" accent="blue">
      <Leaf slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
  </div>

  <!-- Bill comparison chart -->
  <ChartCard title="ค่าไฟ: จ่ายจริง เทียบกับ ถ้าไม่มีโซลาร์" subtitle="คำนวณตามอัตราขั้นบันไดของการไฟฟ้านครหลวง (MEA) รวม Ft และ VAT 7%">
    <div class="flex items-start gap-1">
      <div class="relative shrink-0 overflow-visible" style="width:2.75rem;height:280px">
        {
          billYLabels.map((l, i) => (
            <span
              class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
              style={`top:${billGridPct[i]}%;transform:translateY(-50%)`}
            >
              {l}
            </span>
          ))
        }
      </div>
      <div class="min-w-0 flex-1">
        <div class="chart-frame">
          <svg class="bill-chart-svg" viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
            {billGridYs.map((g) => <line x1={px0} x2={px1} y1={g.y} y2={g.y} stroke="var(--border)" stroke-opacity={g.isMax ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
            {
              billBars.map(({ b1, b2 }) => (
                <>
                  <rect x={b1.x} y={b1.y} width={b1.w} height={b1.h} rx={b1.rx} fill="var(--chart-4)" fill-opacity="0.75" />
                  <rect x={b2.x} y={b2.y} width={b2.w} height={b2.h} rx={b2.rx} fill="var(--chart-1)" fill-opacity="0.85" />
                </>
              ))
            }
            {
              months.map((m: MonthEntry, i: number) => (
                <rect
                  class="bill-hit"
                  x={px0 + i * groupW}
                  y={py0}
                  width={groupW}
                  height={ph}
                  fill="transparent"
                  style="cursor:crosshair"
                  data-month={m.month}
                  data-without={thb(m.billWithoutSolar, 0)}
                  data-with={thb(m.billWithSolar, 0)}
                  data-saved={thb(m.saved, 0)}
                />
              ))
            }
          </svg>
        </div>
        <div class="mt-1 flex justify-between text-[9px] tracking-wider text-muted-foreground" style={`padding-left:${labelPl};padding-right:${labelPr}`}>
          {months.map((m: MonthEntry) => <span>{m.month}</span>)}
        </div>
      </div>
    </div>
    <LegendRow
      class="mt-4"
      items={[
        { label: 'ถ้าไม่มีโซลาร์', color: 'var(--chart-4)' },
        { label: 'จ่ายจริง', color: 'var(--chart-1)' },
      ]}
    />
  </ChartCard>

  <!-- Energy production chart -->
  <ChartCard title="การผลิตไฟ 12 เดือน" subtitle="หน่วยเป็น kWh ต่อเดือน">
    <div class="flex items-start gap-1">
      <div class="relative shrink-0 overflow-visible" style="width:2rem;height:280px">
        {
          energyYLabels.map((l, i) => (
            <span
              class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
              style={`top:${energyGridPct[i]}%;transform:translateY(-50%)`}
            >
              {l}
            </span>
          ))
        }
      </div>
      <div class="min-w-0 flex-1">
        <div class="chart-frame">
          <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
            <defs>
              <linearGradient id="gen-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--chart-2)" stop-opacity="0.35"></stop>
                <stop offset="100%" stop-color="var(--chart-2)" stop-opacity="0"></stop>
              </linearGradient>
              <linearGradient id="self-grad2" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="var(--chart-1)" stop-opacity="0.3"></stop>
                <stop offset="100%" stop-color="var(--chart-1)" stop-opacity="0"></stop>
              </linearGradient>
              <clipPath id="energy-clip"><rect x={px0} y={py0} width={pw} height={ph}></rect></clipPath>
            </defs>
            {energyGridYs.map((g) => <line x1={px0} x2={px1} y1={g.y} y2={g.y} stroke="var(--border)" stroke-opacity={g.isMax ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
            <g clip-path="url(#energy-clip)">
              <path d={genFill} fill="url(#gen-grad)"></path>
              <path d={genLine} fill="none" stroke="var(--chart-2)" stroke-width="1.5" stroke-linecap={'round' as const}></path>
              <path d={selfFill} fill="url(#self-grad2)"></path>
              <path d={selfLine} fill="none" stroke="var(--chart-1)" stroke-width="1.5" stroke-linecap={'round' as const}></path>
            </g>
            <line class="energy-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
            <rect
              class="energy-overlay"
              x={px0}
              y={py0}
              width={pw}
              height={ph}
              fill="transparent"
              style="cursor:crosshair"
              data-px0={px0}
              data-px1={px1}
              data-vw={VW}
              data-gen={JSON.stringify(months.map((m: MonthEntry) => m.generated))}
              data-self={JSON.stringify(months.map((m: MonthEntry) => m.selfUse))}
              data-months={JSON.stringify(months.map((m: MonthEntry) => m.month))}></rect>
          </svg>
        </div>
        <div class="mt-1 flex justify-between text-[9px] tracking-wider text-muted-foreground" style={`padding-left:${labelPl};padding-right:${labelPr}`}>
          {months.map((m: MonthEntry) => <span>{m.month}</span>)}
        </div>
      </div>
    </div>
    <LegendRow
      class="mt-3"
      items={[
        { label: 'ผลิตได้', color: 'var(--chart-2)' },
        { label: 'ใช้จากโซลาร์', color: 'var(--chart-1)' },
      ]}
    />
  </ChartCard>
</div>

<!-- Bill chart tooltip -->
<div class="bill-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:150px">
  <p class="bill-tip-month mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="space-y-1.5">
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-4);opacity:0.75"></span>ไม่มีโซลาร์
      </span>
      <span class="bill-tip-without font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-1)"></span>จ่ายจริง
      </span>
      <span class="bill-tip-with font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4 border-t border-border/50 pt-1.5">
      <span class="text-[11px] text-muted-foreground">ประหยัด</span>
      <span class="bill-tip-saved font-mono text-[11px] font-medium text-chart-1"></span>
    </div>
  </div>
</div>

<!-- Energy chart tooltip -->
<div class="energy-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:140px">
  <p class="energy-tip-month mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="space-y-1.5">
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-2)"></span>ผลิตได้
      </span>
      <span class="energy-tip-gen font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-1)"></span>ใช้จากโซลาร์
      </span>
      <span class="energy-tip-self font-mono text-[11px] text-foreground"></span>
    </div>
  </div>
</div>

<script>
  {
    // Bill bar chart
    const billTip = document.querySelector<HTMLElement>('.bill-chart-tip')
    if (billTip) {
      const monthEl = billTip.querySelector('.bill-tip-month')!
      const withoutEl = billTip.querySelector('.bill-tip-without')!
      const withEl = billTip.querySelector('.bill-tip-with')!
      const savedEl = billTip.querySelector('.bill-tip-saved')!
      document.querySelectorAll<SVGRectElement>('.bill-hit').forEach((r) => {
        r.addEventListener('mouseenter', (e) => {
          const d = (e.currentTarget as SVGRectElement).dataset
          monthEl.textContent = d.month!
          withoutEl.textContent = d.without!
          withEl.textContent = d.with!
          savedEl.textContent = d.saved!
          billTip.classList.remove('hidden')
        })
        r.addEventListener('mousemove', (e) => {
          billTip.style.left = Math.min(e.clientX + 14, window.innerWidth - 170) + 'px'
          billTip.style.top = Math.max(e.clientY - 80, 8) + 'px'
        })
        r.addEventListener('mouseleave', () => billTip.classList.add('hidden'))
      })
    }

    // Energy line chart
    const overlay = document.querySelector<SVGRectElement>('.energy-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.energy-crosshair')
    const energyTip = document.querySelector<HTMLElement>('.energy-chart-tip')
    if (svg && overlay && energyTip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const genData: number[] = JSON.parse(d.gen!)
      const selfData: number[] = JSON.parse(d.self!)
      const months: string[] = JSON.parse(d.months!)
      const n = genData.length
      const monthEl = energyTip.querySelector('.energy-tip-month')!
      const genEl = energyTip.querySelector('.energy-tip-gen')!
      const selfEl = energyTip.querySelector('.energy-tip-self')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          energyTip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = n > 1 ? (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1) : String(px0)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        monthEl.textContent = months[idx]
        genEl.textContent = genData[idx].toFixed(1) + ' kWh'
        selfEl.textContent = selfData[idx].toFixed(1) + ' kWh'
        energyTip.classList.remove('hidden')
        energyTip.style.left = Math.min(e.clientX + 14, window.innerWidth - 160) + 'px'
        energyTip.style.top = Math.max(e.clientY - 70, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        energyTip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
