---
import Sun from '@lucide/svelte/icons/sun'
import Wallet from '@lucide/svelte/icons/wallet'
import PiggyBank from '@lucide/svelte/icons/piggy-bank'
import Leaf from '@lucide/svelte/icons/leaf'
import StatCard from './StatCard.astro'
import { thb, num } from '@/lib/electricity'
import { lineScale } from '@/lib/chart'

interface MonthEntry {
  month: string
  generated: number
  consumed: number
  selfUse: number
  gridImport: number
  billWithSolar: number
  billWithoutSolar: number
  saved: number
}
interface Props {
  months: MonthEntry[]
  lifetime: { generated: number; gridImport: number; generationTime: number; co2ReductionKg: number }
}
const { months, lifetime: LIFETIME } = Astro.props
const current = months[months.length - 1] ?? { generated: 0, selfUse: 0, billWithSolar: 0, billWithoutSolar: 0, saved: 0, month: '' }
const annualSaving = months.reduce((s: number, m: MonthEntry) => s + m.saved, 0)
const billMax = Math.max(...months.map((m: MonthEntry) => m.billWithoutSolar), 1)
const energyMax = Math.max(...months.map((m: MonthEntry) => Math.max(m.generated, m.selfUse)), 1)
const gen = lineScale(
  months.map((m: MonthEntry) => m.generated),
  energyMax,
)
const self = lineScale(
  months.map((m: MonthEntry) => m.selfUse),
  energyMax,
)

// pre-compute chart rows in frontmatter to avoid implicit-any in JSX callbacks
const billRows = months.map((m: MonthEntry) => ({ month: m.month, withoutSolar: m.billWithoutSolar, withSolar: m.billWithSolar, billMax }))
const energyRows = months.map((m: MonthEntry, i: number) => ({ month: m.month, generated: m.generated, selfUse: m.selfUse, gen: gen[i], self: self[i] }))
---

<div class="space-y-6">
  <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
    <StatCard label="ผลิตไฟเดือนนี้" value={`${num(current.generated, 0)} kWh`} sub={`ใช้เอง ${num(current.selfUse, 0)} kWh`} accent="brass">
      <Sun slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ค่าไฟเดือนนี้" value={thb(current.billWithSolar, 0)} sub={`ถ้าไม่มีโซลาร์ ${thb(current.billWithoutSolar, 0)}`} accent="terracotta">
      <Wallet slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ประหยัดเดือนนี้" value={thb(current.saved, 0)} sub={`รวมทั้งปี ~${thb(annualSaving, 0)}`} accent="sage" trend={`${num((current.saved / current.billWithoutSolar) * 100, 0)}%`}>
      <PiggyBank slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
    <StatCard label="ลด CO₂ สะสม" value={`${num(LIFETIME.co2ReductionKg, 0)} kg`} sub="เทียบเท่าปลูกต้นไม้หลายสิบต้น" accent="blue">
      <Leaf slot="icon" size={18} strokeWidth={1.25} />
    </StatCard>
  </div>

  <section class="rounded-lg border border-border/70 bg-card p-6">
    <div class="mb-6">
      <h2 class="font-serif text-lg font-light text-foreground">ค่าไฟ: จ่ายจริง เทียบกับ ถ้าไม่มีโซลาร์</h2>
      <p class="mt-1 text-sm text-muted-foreground">คำนวณตามอัตราขั้นบันไดของการไฟฟ้านครหลวง (MEA) รวม Ft และ VAT 7%</p>
    </div>

    <div class="chart-frame">
      <table class="charts-css column multiple show-labels show-4-secondary-axes" style="--color-1:var(--chart-4);--color-2:var(--chart-1)">
        <tbody>
          {
            billRows.map((r) => (
              <tr>
                <th scope="row">{r.month}</th>
                <td style={`--size:${r.withoutSolar / r.billMax}`}>
                  <span class="data">{r.withoutSolar}</span>
                </td>
                <td style={`--size:${r.withSolar / r.billMax}`}>
                  <span class="data">{r.withSolar}</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-xs text-muted-foreground">
      <span class="flex items-center gap-2"><span class="legend-dot" style="background:var(--chart-4)"></span>ถ้าไม่มีโซลาร์</span>
      <span class="flex items-center gap-2"><span class="legend-dot" style="background:var(--chart-1)"></span>จ่ายจริง</span>
    </div>
  </section>

  <section class="rounded-lg border border-border/70 bg-card p-6">
    <div class="mb-6">
      <h2 class="font-serif text-lg font-light text-foreground">การผลิตไฟ 12 เดือน</h2>
      <p class="mt-1 text-sm text-muted-foreground">หน่วยเป็น kWh ต่อเดือน</p>
    </div>

    <div class="chart-frame">
      <table class="charts-css area multiple show-labels show-4-secondary-axes" style="--color-1:var(--chart-2);--color-2:var(--chart-1)">
        <tbody>
          {
            energyRows.map((r) => (
              <tr>
                <th scope="row">{r.month}</th>
                <td style={`--start:${r.gen.start};--end:${r.gen.end}`}>
                  <span class="data">{r.generated}</span>
                </td>
                <td style={`--start:${r.self.start};--end:${r.self.end}`}>
                  <span class="data">{r.selfUse}</span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2 text-xs text-muted-foreground">
      <span class="flex items-center gap-2"><span class="legend-dot" style="background:var(--chart-2)"></span>ผลิตได้</span>
      <span class="flex items-center gap-2"><span class="legend-dot" style="background:var(--chart-1)"></span>ใช้จากโซลาร์</span>
    </div>
  </section>
</div>
