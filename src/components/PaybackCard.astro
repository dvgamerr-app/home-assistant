---
import TrendingUp from '@lucide/svelte/icons/trending-up'
import CalendarClock from '@lucide/svelte/icons/calendar-clock'
import Coins from '@lucide/svelte/icons/coins'
import { thb, num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'

const { system, payback } = Astro.props as Pick<SolarData, 'system' | 'payback'>
const years = Math.floor(payback.yearsToPayback)
const months = Math.round((payback.yearsToPayback - years) * 12)
const pct = Math.min(100, payback.progressPct)

const metrics = [
  { Icon: Coins, label: 'ประหยัดเฉลี่ย/เดือน', value: thb(payback.monthlyAvgSaving, 0), tone: 'text-chart-2' },
  { Icon: TrendingUp, label: 'ประหยัดต่อปี', value: thb(payback.annualSaving, 0), tone: 'text-chart-1' },
  { Icon: CalendarClock, label: 'คืนทุนครบในอีก', value: `${years} ปี ${months} เดือน`, tone: 'text-chart-3' },
]
---

<section class="overflow-hidden rounded-lg border border-border/70 bg-card">
  <div class="border-b border-border/60 p-6 md:p-8">
    <div class="flex items-center gap-2 text-muted-foreground">
      <TrendingUp size={16} strokeWidth={1.25} />
      <h2 class="text-[10px] uppercase tracking-luxury">ความคืบหน้าการคืนทุน</h2>
    </div>
    <p class="mt-4 font-serif text-5xl font-light text-foreground md:text-6xl">{num(payback.progressPct, 1)}<span class="text-2xl text-muted-foreground">%</span></p>
    <p class="mt-2 text-sm text-muted-foreground">
      คืนทุนแล้ว {thb(payback.totalSavedToDate, 0)} จากเงินลงทุน {thb(system.investmentTHB, 0)}
    </p>
    <div class="mt-6 h-px w-full bg-border">
      <div class="h-px bg-accent" style={`width:${pct}%`}></div>
    </div>
  </div>

  <dl class="grid grid-cols-1 divide-y divide-border/60 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
    {
      metrics.map(({ Icon, label, value, tone }) => (
        <div class="flex items-start gap-3 p-6">
          <span class={tone}>
            <Icon size={18} strokeWidth={1.25} />
          </span>
          <div class="space-y-1">
            <dt class="text-[10px] uppercase tracking-luxury text-muted-foreground">{label}</dt>
            <dd class="font-serif text-xl font-light text-foreground">{value}</dd>
          </div>
        </div>
      ))
    }
  </dl>
</section>
