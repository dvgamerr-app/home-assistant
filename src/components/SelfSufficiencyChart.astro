---
import { MONTHS } from '@/lib/solar-data'
import { lineScale } from '@/lib/chart'

const data = MONTHS.map((m) => ({ month: m.month, ratio: Math.round((m.selfUse / m.consumed) * 100) }))
const r = lineScale(
  data.map((d) => d.ratio),
  100,
)
---

<section class="rounded-lg border border-border/70 bg-card p-6">
  <div class="mb-6">
    <h2 class="font-serif text-lg font-light text-foreground">การพึ่งพาตัวเองรายเดือน</h2>
    <p class="mt-1 text-sm leading-relaxed text-muted-foreground">สัดส่วนไฟที่ใช้เองจากโซลาร์เทียบกับไฟที่ใช้ทั้งหมด — ยิ่งสูงยิ่งซื้อไฟจากการไฟฟ้าน้อย</p>
  </div>

  <div class="chart-frame">
    <table class="charts-css line show-labels show-4-secondary-axes" style="--color-1:var(--chart-1)">
      <tbody>
        {
          data.map((d, i) => (
            <tr>
              <th scope="row">{d.month}</th>
              <td style={`--start:${r[i].start};--end:${r[i].end}`}>
                <span class="data">{d.ratio}%</span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-5 flex items-center gap-2 text-xs text-muted-foreground">
    <span class="legend-dot" style="background:var(--chart-1)"></span>พึ่งพาตัวเอง (%)
  </div>
</section>
