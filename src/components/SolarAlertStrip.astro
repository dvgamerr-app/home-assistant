---
import type { SolarData } from '@/lib/solar-data'

const { freshness, alerts } = Astro.props as Pick<SolarData, 'freshness' | 'alerts'>

const toneMap = {
  ok: 'border-chart-1/30 bg-chart-1/8 text-chart-1',
  info: 'border-chart-3/25 bg-chart-3/8 text-chart-3',
  warn: 'border-chart-2/30 bg-chart-2/10 text-chart-2',
  danger: 'border-chart-4/30 bg-chart-4/10 text-chart-4',
} as const

const freshnessNote = freshness.isOnline ? (freshness.ageMinutes <= 1 ? 'ข้อมูลเพิ่งอัปเดต' : `ช้ากว่าเวลาจริง ${freshness.ageMinutes} นาที`) : 'ระบบยังไม่ส่งข้อมูลเพิ่ม'
---

<section class="rounded-lg border border-border/70 bg-card p-6">
  <div class="flex flex-wrap items-start justify-between gap-4 border-b border-border/60 pb-4">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ความพร้อมของข้อมูล</p>
      <h2 class="font-serif text-lg font-light text-foreground">สถานะข้อมูลสดและสัญญาณระบบ</h2>
      <p class="text-sm text-muted-foreground">ช่วยดูว่าข้อมูลที่กำลังเห็นยังทันสมัยอยู่หรือไม่ และมีจุดไหนที่ควรเฝ้าดูเป็นพิเศษ</p>
    </div>
    <div class="text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">อัปเดตล่าสุด</p>
      <p class="mt-1 font-serif text-xl font-light text-foreground">{freshness.lastUpdateLabel}</p>
      <p class="mt-1 text-xs text-muted-foreground">{freshnessNote}</p>
    </div>
  </div>

  <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
    {
      alerts.map((alert) => (
        <div class:list={['rounded-md border px-4 py-3', toneMap[alert.tone]]}>
          <p class="text-[10px] uppercase tracking-luxury opacity-80">{alert.title}</p>
          <p class="mt-1.5 text-sm leading-relaxed text-foreground">{alert.detail}</p>
        </div>
      ))
    }
  </div>
</section>
