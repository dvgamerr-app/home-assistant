---
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'

const { dayFlow, dayComparison } = Astro.props as Pick<SolarData, 'dayFlow' | 'dayComparison'>

function deltaText(value: { diff: number; pct: number | null } | undefined, unit: string) {
  if (!value) return 'ยังไม่มีข้อมูลเปรียบเทียบ'
  const sign = value.diff > 0 ? '+' : value.diff < 0 ? '−' : ''
  const abs = Math.abs(value.diff)
  const pctLabel = value.pct === null ? '' : ` (${sign}${Math.abs(value.pct)}%)`
  return `${sign}${num(abs, 1)} ${unit}${pctLabel} เทียบเมื่อวาน`
}
---

<section class="rounded-lg border border-border/70 bg-card p-6">
  <div class="flex flex-wrap items-start justify-between gap-4 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">มุมมองรายวัน</p>
      <h2 class="font-serif text-lg font-light text-foreground">สรุปการผลิตและการพึ่งพาตัวเอง</h2>
      <p class="text-sm text-muted-foreground">วันที่ {dayFlow.date} ช่วยให้เห็นว่าไฟที่ผลิตได้ถูกใช้ในบ้านมากแค่ไหน ต้องซื้อไฟเพิ่มเท่าไร และเหลือส่วนเกินมากน้อยเพียงใด</p>
    </div>
    <div class="text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">เฉลี่ย 7 วันก่อนหน้า</p>
      <p class="mt-1 font-serif text-2xl font-light text-foreground">{num(dayComparison.trailing7Avg.generated, 1)}<span class="ml-1 text-sm text-muted-foreground">kWh ผลิต</span></p>
      <p class="mt-1 text-xs text-muted-foreground">พึ่งพาตัวเองเฉลี่ย {num(dayComparison.trailing7Avg.selfSufficiencyPct, 0)}%</p>
    </div>
  </div>

  <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-md border border-border/60 p-4">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ผลิตได้ทั้งวัน</p>
      <p class="mt-2 font-serif text-3xl font-light text-foreground">{num(dayFlow.generated, 1)}<span class="ml-1 text-base text-muted-foreground">kWh</span></p>
      <p class="mt-2 text-xs text-muted-foreground">{deltaText(dayComparison.deltaFromPrevious?.generated, 'kWh')}</p>
    </div>

    <div class="rounded-md border border-border/60 p-4">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พึ่งพาตัวเอง</p>
      <p class="mt-2 font-serif text-3xl font-light text-foreground">{num(dayFlow.selfSufficiencyPct, 0)}<span class="ml-1 text-base text-muted-foreground">%</span></p>
      <p class="mt-2 text-xs text-muted-foreground">{num(dayFlow.selfPowered, 1)} kWh มาจากไฟที่ผลิตและแบตเตอรี่</p>
      <p class="mt-1 text-xs text-muted-foreground">{deltaText(dayComparison.deltaFromPrevious?.selfSufficiencyPct, '%')}</p>
    </div>

    <div class="rounded-md border border-border/60 p-4">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ซื้อไฟจากกริด</p>
      <p class="mt-2 font-serif text-3xl font-light text-foreground">{num(dayFlow.gridImport, 1)}<span class="ml-1 text-base text-muted-foreground">kWh</span></p>
      <p class="mt-2 text-xs text-muted-foreground">คิดเป็น {num(dayFlow.gridDependencyPct, 0)}% ของการใช้ไฟทั้งวัน</p>
      <p class="mt-1 text-xs text-muted-foreground">{deltaText(dayComparison.deltaFromPrevious?.gridImport, 'kWh')}</p>
    </div>

    <div class="rounded-md border border-border/60 p-4">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ส่วนเกินหลังชาร์จแบต</p>
      <p class="mt-2 font-serif text-3xl font-light text-foreground">{num(dayFlow.solarSurplusKwh, 1)}<span class="ml-1 text-base text-muted-foreground">kWh</span></p>
      <p class="mt-2 text-xs text-muted-foreground">ประเมินจากกำลังผลิตและกำลังชาร์จ/จ่ายของแบตตลอดวัน</p>
      <p class="mt-1 text-xs text-muted-foreground">คิดเป็น {num(dayFlow.solarSurplusPct, 0)}% ของพลังงานที่ผลิตได้</p>
    </div>
  </div>

  <div class="mt-5 grid gap-4 border-t border-border/60 pt-5 md:grid-cols-3">
    <div>
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ชาร์จเข้าแบตเตอรี่</p>
      <p class="mt-1 font-serif text-2xl font-light text-foreground">{num(dayFlow.batteryChargeKwh, 1)}<span class="ml-1 text-sm text-muted-foreground">kWh</span></p>
      <p class="mt-1 text-xs text-muted-foreground">ช่วยบอกว่าช่วงกลางวันเก็บพลังงานสำรองไว้มากแค่ไหน</p>
    </div>
    <div>
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">จ่ายจากแบตเตอรี่</p>
      <p class="mt-1 font-serif text-2xl font-light text-foreground">{num(dayFlow.batteryDischargeKwh, 1)}<span class="ml-1 text-sm text-muted-foreground">kWh</span></p>
      <p class="mt-1 text-xs text-muted-foreground">ช่วยลดการซื้อไฟช่วงที่แสงแดดไม่พอ</p>
    </div>
    <div>
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">อ้างอิง 7 วันก่อนหน้า</p>
      <p class="mt-1 font-serif text-2xl font-light text-foreground">{num(dayComparison.trailing7Avg.gridImport, 1)}<span class="ml-1 text-sm text-muted-foreground">kWh ซื้อจากกริด</span></p>
      <p class="mt-1 text-xs text-muted-foreground">ผลิตเฉลี่ย {num(dayComparison.trailing7Avg.generated, 1)} kWh ต่อวัน</p>
    </div>
  </div>
</section>
