---
import { svgLine, svgArea } from '@/lib/chart'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'

const { hourlySoc: HOURLY_SOC } = Astro.props as Pick<SolarData, 'hourlySoc'>
const displaySoc = (value: number) => (value >= 99.5 ? 100 : Math.round(value))

const [VW, VH, ML, MT, MR, MB] = [560, 220, 4, 18, 8, 28]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const ph = py1 - py0

// ตัดชั่วโมงอนาคต (ค่า 0) ออก แล้ว scale x ให้ตรงกับ label 24 ชม.
const currentHour = new Date().getHours()
const active = HOURLY_SOC.slice(0, Math.min(currentHour + 1, HOURLY_SOC.length))
const xEnd = active.length <= 1 ? px0 : px0 + ((active.length - 1) / 23) * (px1 - px0)
const vals = active.map((r) => r.soc / 100)

const nonZero = active.filter((r) => r.soc > 0)
const currentSoc = active[active.length - 1]?.soc ?? 0
const minSoc = nonZero.length > 0 ? Math.min(...nonZero.map((r) => r.soc)) : 0
const maxSoc = nonZero.length > 0 ? Math.max(...nonZero.map((r) => r.soc)) : 0

const linePath = svgLine(vals, px0, py0, xEnd, py1)
const fillPath = svgArea(vals, px0, py0, xEnd, py1)
const yTicks = [1, 0.75, 0.5, 0.25]
const gridYs = yTicks.map((f) => +(py0 + (1 - f) * ph).toFixed(1))
const gridPct = yTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)
const xLabels = Array.from({ length: 24 }, (_, i) => String(i).padStart(2, '0'))
const yLabels = ['100%', '75%', '50%', '25%']
---

<ChartCard eyebrow="แบตเตอรี่" title="ระดับพลังงานสำรองระหว่างวัน" class="flex flex-col overflow-hidden">
  <div class="flex items-end gap-8 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ล่าสุด</p>
      <p class="font-serif text-4xl font-light leading-none">
        {displaySoc(currentSoc)}<span class="ml-1 text-base text-muted-foreground">%</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ต่ำสุดวันนี้</p>
      <p class="font-serif text-2xl font-light leading-none text-muted-foreground">{displaySoc(minSoc)}%</p>
    </div>
    <div class="ml-auto space-y-1 text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">สูงสุดวันนี้</p>
      <p class="font-serif text-lg text-foreground">{displaySoc(maxSoc)}%</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative h-56 shrink-0 overflow-visible md:h-60" style="width:1.75rem">
      {
        yLabels.map((l, i) => (
          <span
            class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
            style={`top:${gridPct[i]}%;transform:translateY(-50%)`}
          >
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="h-56 w-full md:h-60">
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <defs>
            <linearGradient id="soc-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--chart-1)" stop-opacity="0.35"></stop>
              <stop offset="100%" stop-color="var(--chart-1)" stop-opacity="0"></stop>
            </linearGradient>
            <clipPath id="soc-clip"><rect x={px0} y={py0} width={px1 - px0} height={ph}></rect></clipPath>
          </defs>
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y, i) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity={i === 0 ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
          <g clip-path="url(#soc-clip)">
            <path d={fillPath} fill="url(#soc-grad)"></path>
            <path d={linePath} fill="none" stroke="var(--chart-1)" stroke-width="1.5" stroke-linecap={'round' as const} stroke-linejoin={'round' as const}></path>
          </g>
          <line class="soc-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
          <rect
            class="soc-overlay"
            x={px0}
            y={py0}
            width={xEnd - px0}
            height={ph}
            fill="transparent"
            style="cursor:crosshair"
            data-px0={px0}
            data-px1={px1}
            data-vw={VW}
            data-soc={JSON.stringify(active.map((r) => r.soc))}></rect>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {xLabels.map((l) => <span>{l}</span>)}
      </div>
    </div>
  </div>

  <LegendRow class="mt-3" items={[{ label: 'ระดับแบตเตอรี่ (%)', color: 'var(--chart-1)' }]} />
</ChartCard>

<div class="soc-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:130px">
  <p class="soc-tip-hour mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="flex items-center justify-between gap-4">
    <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
      <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-1)"></span>SOC
    </span>
    <span class="soc-tip-val font-mono text-[11px] font-medium text-foreground"></span>
  </div>
</div>

<script>
  {
    const overlay = document.querySelector<SVGRectElement>('.soc-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.soc-crosshair')
    const tip = document.querySelector<HTMLElement>('.soc-chart-tip')
    if (svg && overlay && tip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const socData: number[] = JSON.parse(d.soc!)
      const n = socData.length
      const hourEl = tip.querySelector('.soc-tip-hour')!
      const valEl = tip.querySelector('.soc-tip-val')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          tip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = n > 1 ? (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1) : String(px0)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        hourEl.textContent = String(idx).padStart(2, '0') + ':00 น.'
        valEl.textContent = Math.round(socData[idx]) + '%'
        tip.classList.remove('hidden')
        tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 160) + 'px'
        tip.style.top = Math.max(e.clientY - 70, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        tip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
