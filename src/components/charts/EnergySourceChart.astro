---
import { svgStackedBars } from '@/lib/chart'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'

const { hourly: HOURLY } = Astro.props as Pick<SolarData, 'hourly'>

// แหล่งจ่ายไฟ 3 ชั้น: โซลาร์ → แบตจ่าย → กริด
// sign: batt+ = discharging, grid- = importing
const bars = HOURLY.map((h) => {
  const solar = Math.max(0, Math.min(h.pv, h.load))
  const battDis = Math.max(0, h.batt ?? 0)
  const gridImp = Math.max(0, -(h.grid ?? 0))
  return [solar, battDis, gridImp]
})

const currentHour = new Date().getHours()
const activeBars = bars.map((b, i) => (i <= currentHour ? b : [0, 0, 0]))

const [VW, VH, ML, MT, MR, MB] = [560, 200, 4, 16, 4, 28]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]

const rects = svgStackedBars(activeBars, px0, py0, px1, py1, 0.18)

const maxTotal = Math.max(...activeBars.map((b) => b.reduce((s, v) => s + v, 0)), 1)
const yTicks = [1, 0.75, 0.5, 0.25]
const ph = py1 - py0
const gridYs = yTicks.map((f) => +(py0 + (1 - f) * ph).toFixed(1))
const gridPct = yTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const yLabels = yTicks.map((f) => num(maxTotal * f, 1))
const xLabels = Array.from({ length: 24 }, (_, i) => String(i).padStart(2, '0'))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)

const colors = ['var(--chart-2)', 'var(--chart-1)', 'var(--chart-4)']
const colorOpacity = ['0.75', '0.75', '0.75']

// สถิติวันนี้
const totalSolar = HOURLY.reduce((s, h) => s + Math.max(0, Math.min(h.pv, h.load)), 0)
const totalBatt = HOURLY.reduce((s, h) => s + Math.max(0, h.batt ?? 0), 0)
const totalGrid = HOURLY.reduce((s, h) => s + Math.max(0, -(h.grid ?? 0)), 0)
const gridHours = HOURLY.filter((h) => (h.grid ?? 0) < -0.05).length
---

<ChartCard eyebrow="แหล่งจ่ายไฟ" title="พลังงานที่บ้านใช้รายชั่วโมง" class="flex flex-col overflow-hidden">
  <div class="flex flex-wrap items-end gap-6 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">โซลาร์ใช้เอง</p>
      <p class="font-serif text-4xl font-light leading-none" style="color:var(--chart-2)">
        {num(totalSolar, 1)}<span class="ml-1 text-base text-muted-foreground">kWh</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">แบตจ่ายเสริม</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-1)">{num(totalBatt, 1)} kWh</p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ซื้อจากกริด</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-4)">{num(totalGrid, 1)} kWh</p>
    </div>
    <div class="ml-auto space-y-1 text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ชม. ที่ใช้กริด</p>
      <p class="font-serif text-lg text-foreground">{gridHours} ชม.</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative shrink-0 overflow-visible" style="width:1.75rem;height:calc(var(--chart-h, 14rem))">
      {
        yLabels.map((l, i) => (
          <span
            class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
            style={`top:${gridPct[i]}%;transform:translateY(-50%)`}
          >
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="h-56 w-full md:h-60">
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity="0.5" stroke-width="0.5" stroke-dasharray="2 4" />)}
          {
            rects.map((bar) =>
              bar.map((seg, j) =>
                seg.h > 0 ? <rect x={seg.x.toFixed(1)} y={seg.y.toFixed(1)} width={seg.w.toFixed(1)} height={seg.h.toFixed(1)} rx={seg.rx} fill={colors[j]} fill-opacity={colorOpacity[j]} /> : null,
              ),
            )
          }
          <!-- invisible overlay for tooltip -->
          <rect
            class="esrc-overlay"
            x={px0}
            y={py0}
            width={px1 - px0}
            height={py1 - py0}
            fill="transparent"
            style="cursor:crosshair"
            data-px0={px0}
            data-px1={px1}
            data-vw={VW}
            data-solar={JSON.stringify(HOURLY.map((h) => Math.max(0, Math.min(h.pv, h.load))))}
            data-batt={JSON.stringify(HOURLY.map((h) => Math.max(0, h.batt ?? 0)))}
            data-grid={JSON.stringify(HOURLY.map((h) => Math.max(0, -(h.grid ?? 0))))}></rect>
          <line class="esrc-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {xLabels.map((l) => <span>{l}</span>)}
      </div>
    </div>
  </div>

  <LegendRow
    class="mt-3"
    items={[
      { label: 'โซลาร์ (kW)', color: 'var(--chart-2)' },
      { label: 'แบตเตอรี่จ่าย (kW)', color: 'var(--chart-1)' },
      { label: 'กริด (kW)', color: 'var(--chart-4)' },
    ]}
  />
</ChartCard>

<div class="esrc-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:150px">
  <p class="esrc-tip-hour mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="space-y-1.5">
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-sm" style="background:var(--chart-2)"></span>โซลาร์
      </span>
      <span class="esrc-tip-solar font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-sm" style="background:var(--chart-1)"></span>แบตจ่าย
      </span>
      <span class="esrc-tip-batt font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-sm" style="background:var(--chart-4)"></span>กริด
      </span>
      <span class="esrc-tip-grid font-mono text-[11px] text-foreground"></span>
    </div>
  </div>
</div>

<script>
  {
    const overlay = document.querySelector<SVGRectElement>('.esrc-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.esrc-crosshair')
    const tip = document.querySelector<HTMLElement>('.esrc-chart-tip')
    if (svg && overlay && tip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const solar: number[] = JSON.parse(d.solar!)
      const batt: number[] = JSON.parse(d.batt!)
      const grid: number[] = JSON.parse(d.grid!)
      const n = 24
      const hourEl = tip.querySelector('.esrc-tip-hour')!
      const solarEl = tip.querySelector('.esrc-tip-solar')!
      const battEl = tip.querySelector('.esrc-tip-batt')!
      const gridEl = tip.querySelector('.esrc-tip-grid')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          tip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        hourEl.textContent = String(idx).padStart(2, '0') + ':00 น.'
        solarEl.textContent = solar[idx].toFixed(2) + ' kW'
        battEl.textContent = batt[idx].toFixed(2) + ' kW'
        gridEl.textContent = grid[idx].toFixed(2) + ' kW'
        tip.classList.remove('hidden')
        tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 180) + 'px'
        tip.style.top = Math.max(e.clientY - 80, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        tip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
