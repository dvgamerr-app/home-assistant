---
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'
import { svgLine } from '@/lib/chart'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'

const { months, gridOverview } = Astro.props as Pick<SolarData, 'months' | 'gridOverview'>

const sufficiencyVals = months.map((month) => month.selfSufficiencyPct / 100)
const dependencyVals = months.map((month) => month.gridDependencyPct / 100)
const surplusVals = months.map((month) => month.solarSurplusPct / 100)

const [VW, VH, ML, MT, MR, MB] = [560, 180, 4, 10, 8, 24]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const ph = py1 - py0
const yTicks = [1, 0.75, 0.5, 0.25]
const gridYs = yTicks.map((tick) => py0 + (1 - tick) * ph)
const sufficiencyPath = svgLine(sufficiencyVals.length > 1 ? sufficiencyVals : [0, 0], px0, py0, px1, py1)
const dependencyPath = svgLine(dependencyVals.length > 1 ? dependencyVals : [0, 0], px0, py0, px1, py1)
const surplusPath = svgLine(surplusVals.length > 1 ? surplusVals : [0, 0], px0, py0, px1, py1)
---

<ChartCard eyebrow="พึ่งพากริด" title="ภาพรวมรายเดือนของการพึ่งพาตัวเอง" subtitle="ช่วยดูว่าแต่ละเดือนต้องซื้อไฟจากกริดเท่าไร และมีพลังงานส่วนเกินมากน้อยเพียงใด">
  <div class="grid gap-4 border-b border-border/60 pb-5 md:grid-cols-3">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">เดือนล่าสุด</p>
      <p class="font-serif text-3xl font-light text-foreground">{gridOverview.monthLabel}</p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พึ่งพาตัวเอง</p>
      <p class="font-serif text-2xl font-light text-foreground">{num(gridOverview.selfSufficiencyPct, 0)}<span class="ml-1 text-base text-muted-foreground">%</span></p>
      <p class="text-sm text-muted-foreground">ซื้อไฟจากกริด {num(gridOverview.gridDependencyPct, 0)}%</p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ผลิตเกินจากการใช้</p>
      <p class="font-serif text-2xl font-light text-foreground">{num(gridOverview.solarSurplusKwh, 0)}<span class="ml-1 text-base text-muted-foreground">kWh</span></p>
      <p class="text-sm text-muted-foreground">คิดเป็น {num(gridOverview.solarSurplusPct, 0)}% ของพลังงานที่ผลิตได้</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative h-44 shrink-0 overflow-visible" style="width:1.75rem">
      <span class="absolute right-0 text-[9px] leading-none text-foreground/60" style="top:5%;transform:translateY(-50%)">100%</span>
      <span class="absolute right-0 text-[9px] leading-none text-muted-foreground" style="top:34%;transform:translateY(-50%)">75%</span>
      <span class="absolute right-0 text-[9px] leading-none text-muted-foreground" style="top:63%;transform:translateY(-50%)">50%</span>
      <span class="absolute right-0 text-[9px] leading-none text-muted-foreground" style="top:92%;transform:translateY(-50%)">25%</span>
    </div>
    <div class="min-w-0 flex-1">
      <div class="h-44 w-full">
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y, index) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity={index === 0 ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
          <path d={sufficiencyPath} fill="none" stroke="var(--chart-1)" stroke-width="1.5" stroke-linecap={'round' as const} stroke-linejoin={'round' as const}></path>
          <path d={dependencyPath} fill="none" stroke="var(--chart-4)" stroke-width="1.2" stroke-linecap={'round' as const} stroke-linejoin={'round' as const} stroke-dasharray="4 3"></path>
          <path d={surplusPath} fill="none" stroke="var(--chart-2)" stroke-width="1.1" stroke-linecap={'round' as const} stroke-linejoin={'round' as const} stroke-dasharray="2 3"></path>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] tracking-wider text-muted-foreground">
        {months.map((month) => <span>{month.month}</span>)}
      </div>
    </div>
  </div>

  <LegendRow
    class="mt-3"
    items={[
      { label: 'พึ่งพาตัวเอง', color: 'var(--chart-1)' },
      { label: 'ซื้อจากกริด', color: 'var(--chart-4)' },
      { label: 'ผลิตเกินจากการใช้', color: 'var(--chart-2)' },
    ]}
  />
</ChartCard>
