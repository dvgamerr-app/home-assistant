---
import { svgStackedBars } from '@/lib/chart'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'

const { hourly: HOURLY } = Astro.props as Pick<SolarData, 'hourly'>

// grid negative = importing → negate to get positive import value
const gridImport = HOURLY.map((h) => Math.max(0, -(h.grid ?? 0)))

const currentHour = new Date().getHours()
const activeBars = gridImport.map((v, i) => (i <= currentHour ? [v] : [0]))

const [VW, VH, ML, MT, MR, MB] = [560, 160, 4, 16, 4, 28]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]

const rects = svgStackedBars(activeBars, px0, py0, px1, py1, 0.18)

const maxGrid = Math.max(...gridImport, 0.1)
const ph = py1 - py0
const yTicks = [1, 0.5]
const gridYs = yTicks.map((f) => +(py0 + (1 - f) * ph).toFixed(1))
const gridPct = yTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const yLabels = yTicks.map((f) => num(maxGrid * f, 2))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)
const xLabels = Array.from({ length: 24 }, (_, i) => String(i).padStart(2, '0'))

const totalGridKwh = gridImport.reduce((s, v) => s + v, 0)
const gridHours = gridImport.filter((v) => v > 0.05).length
const peakGrid = Math.max(...gridImport, 0)
---

<ChartCard eyebrow="การพึ่งพากริด" title="ชั่วโมงที่ซื้อไฟฟ้า" class="flex flex-col overflow-hidden">
  <div class="flex flex-wrap items-end gap-6 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ซื้อวันนี้</p>
      <p class="font-serif text-4xl font-light leading-none" style="color:var(--chart-4)">
        {num(totalGridKwh, 2)}<span class="ml-1 text-base text-muted-foreground">kWh</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ชม. ที่ซื้อ</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-4)">{gridHours} ชม.</p>
    </div>
    <div class="ml-auto space-y-1 text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พีคกริด</p>
      <p class="font-serif text-lg text-foreground">{num(peakGrid, 2)} kW</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative shrink-0 overflow-visible" style={`width:1.75rem;height:${VH - MB}px`}>
      {
        yLabels.map((l, i) => (
          <span class="absolute right-0 text-right text-[9px] leading-none text-muted-foreground" style={`top:${gridPct[i]}%;transform:translateY(-50%)`}>
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="w-full" style={`height:${VH - MB}px`}>
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity="0.4" stroke-width="0.5" stroke-dasharray="2 4" />)}
          {
            rects.map((bar, i) =>
              bar[0].h > 0 ? (
                <rect
                  x={bar[0].x.toFixed(1)}
                  y={bar[0].y.toFixed(1)}
                  width={bar[0].w.toFixed(1)}
                  height={bar[0].h.toFixed(1)}
                  rx={bar[0].rx}
                  fill="var(--chart-4)"
                  fill-opacity={gridImport[i] > 0.05 ? '0.75' : '0.2'}
                />
              ) : (
                <rect x={bar[0].x.toFixed(1)} y={(py1 - 2).toFixed(1)} width={bar[0].w.toFixed(1)} height="2" rx="1" fill="var(--border)" fill-opacity="0.5" />
              ),
            )
          }
          <line class="gu-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
          <rect
            class="gu-overlay"
            x={px0}
            y={py0}
            width={px1 - px0}
            height={py1 - py0}
            fill="transparent"
            style="cursor:crosshair"
            data-px0={px0}
            data-px1={px1}
            data-vw={VW}
            data-grid={JSON.stringify(gridImport)}></rect>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {xLabels.map((l) => <span>{l}</span>)}
      </div>
    </div>
  </div>

  <LegendRow class="mt-3" items={[{ label: 'กำลังไฟที่ซื้อจากการไฟฟ้า (kW)', color: 'var(--chart-4)' }]} />
</ChartCard>

<div class="gu-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:140px">
  <p class="gu-tip-hour mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="flex items-center justify-between gap-4">
    <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
      <span class="h-2 w-2 shrink-0 rounded-sm" style="background:var(--chart-4)"></span>กริด
    </span>
    <span class="gu-tip-val font-mono text-[11px] text-foreground"></span>
  </div>
</div>

<script>
  {
    const overlay = document.querySelector<SVGRectElement>('.gu-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.gu-crosshair')
    const tip = document.querySelector<HTMLElement>('.gu-chart-tip')
    if (svg && overlay && tip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const gridData: number[] = JSON.parse(d.grid!)
      const n = 24
      const hourEl = tip.querySelector('.gu-tip-hour')!
      const valEl = tip.querySelector('.gu-tip-val')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          tip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        hourEl.textContent = String(idx).padStart(2, '0') + ':00 น.'
        valEl.textContent = gridData[idx] > 0.01 ? gridData[idx].toFixed(2) + ' kW' : 'ไม่ได้ซื้อไฟ'
        tip.classList.remove('hidden')
        tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 170) + 'px'
        tip.style.top = Math.max(e.clientY - 70, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        tip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
