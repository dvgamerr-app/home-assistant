---
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'
import DatePicker from '@/components/ui/DatePicker.svelte'

const { fiveMin: POINTS, date } = Astro.props as Pick<SolarData, 'fiveMin'> & { date: string }

const [VW, VH, ML, MT, MR, MB] = [560, 220, 4, 18, 8, 28]
const [py0, py1] = [MT, VH - MB]
const ph = py1 - py0

const now = new Date()
const todayISO = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`
const isToday = date === todayISO
const currentMinute = isToday ? now.getHours() * 60 + now.getMinutes() : 1439
// ข้อมูลมาจาก recorded_at จริง จึงใช้ทุก point ที่ <= เวลาปัจจุบัน
const active = POINTS.filter((p) => p.minuteOfDay <= currentMinute)

// unified scale รองรับค่าลบ (battery charging)
const battVals = active.map((h) => h.batt ?? 0)
const gridVals = active.map((h) => h.grid ?? 0) // negative = importing from grid

const dataMax = Math.max(...active.map((h) => Math.max(h.pv, h.load)), 1)
const dataMin = Math.min(0, ...battVals, ...gridVals)

// nice step: round up to 1 sig fig → equal interval both sides
const rawStep = dataMax / 4
const mag = Math.pow(10, Math.floor(Math.log10(rawStep)))
const step = Math.ceil(rawStep / mag) * mag

const numPos = Math.ceil(dataMax / step)
const hasNegative = dataMin < -0.05
const numNeg = hasNegative ? Math.ceil(Math.abs(dataMin) / step) : 0
const scaleMax = numPos * step
const scaleMin = -numNeg * step
const range = scaleMax - scaleMin
const norm = (v: number) => (v - scaleMin) / range

const peakPv = Math.max(...POINTS.map((h) => h.pv))
const peakLoad = Math.max(...POINTS.map((h) => h.load))
const peakBattDis = Math.max(...battVals, 0)

// y-axis ticks: equal interval, include 0 (JS draws grid lines; server only needs gridPct for HTML labels)
const yTicks = [...Array.from({ length: numPos }, (_, i) => (numPos - i) * step), 0, ...(hasNegative ? Array.from({ length: numNeg }, (_, i) => -(i + 1) * step) : [])]
const gridPct = yTicks.map((v) => +(((MT + (1 - norm(v)) * ph) / VH) * 100).toFixed(2))
const yLabels = yTicks.map((v) => (v < 0 ? '−' : '') + num(Math.abs(v), 1))
const tickNorms = yTicks.map((v) => norm(v))
const xLabels = Array.from({ length: 24 }, (_, i) => String(i).padStart(2, '0'))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)

// data passed to client-side draw()
const chartJson = JSON.stringify({
  pv: active.map((h) => h.pv),
  load: active.map((h) => h.load),
  batt: active.map((h) => h.batt ?? 0),
  grid: active.map((h) => h.grid ?? 0),
  times: active.map((h) => h.minuteOfDay),
  scaleMin,
  scaleMax,
  hasNeg: hasNegative,
  tickNorms,
  gridPct,
  yLabels,
  isToday,
})
---

<ChartCard eyebrow="พลังงาน" title="กราฟกำลังผลิตรายชั่วโมง" class="flex flex-col overflow-hidden">
  <div class="flex flex-wrap items-end gap-6 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พีคโซลาร์</p>
      <p class="font-serif text-4xl font-light leading-none">
        <span id="pv-peak-pv">{num(peakPv, 2)}</span><span class="ml-1 text-base text-muted-foreground">kW</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พีคโหลด</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--destructive)"><span id="pv-peak-load">{num(peakLoad, 2)}</span> kW</p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">แบตจ่ายออกสูงสุด</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-3)"><span id="pv-peak-batt">{num(peakBattDis, 2)}</span> kW</p>
    </div>
    <div class="ml-auto flex items-center">
      <DatePicker selected={date} client:load />
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div id="pv-y-axis" class="relative h-56 shrink-0 overflow-visible md:h-60" style="width:1.75rem">
      {
        yLabels.map((l, i) => (
          <span
            class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
            style={`top:${gridPct[i]}%;transform:translateY(-50%)`}
          >
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="pv-chart-wrapper h-56 w-full md:h-60" data-chart={chartJson}>
        <svg width="100%" height="100%"></svg>
      </div>
      <div id="pv-x-axis" class="mt-1 flex justify-between text-[9px] text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {xLabels.map((l) => <span>{l}</span>)}
      </div>
    </div>
  </div>

  <LegendRow
    class="mt-3"
    items={[
      { label: 'โซลาร์ (kW)', color: 'var(--chart-2)' },
      { label: 'โหลด (kW)', color: 'var(--destructive)' },
      { label: 'แบตเตอรี่ (kW)', color: 'var(--chart-3)' },
    ]}
  >
    <span class="flex items-center gap-2 text-xs text-muted-foreground">
      <span class="inline-block h-px w-5 border-t-2 border-dashed opacity-70" style="border-color:var(--chart-4)"></span>
      กริด (kW)
    </span>
  </LegendRow>
</ChartCard>

<div class="pv-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:160px">
  <p class="pv-tip-hour mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="space-y-1.5">
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-2)"></span>โซลาร์
      </span>
      <span class="pv-tip-pv font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--destructive)"></span>โหลด
      </span>
      <span class="pv-tip-load font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-3)"></span>แบตเตอรี่
      </span>
      <span class="pv-tip-batt font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full opacity-70" style="background:var(--chart-4)"></span>กริด
      </span>
      <span class="pv-tip-grid font-mono text-[11px] text-foreground"></span>
    </div>
  </div>
</div>

<script>
  {
    const wrapEl = document.querySelector<HTMLElement>('.pv-chart-wrapper')
    const svg = wrapEl?.querySelector<SVGSVGElement>('svg')
    const tip = document.querySelector<HTMLElement>('.pv-chart-tip')
    const xAxis = document.querySelector<HTMLElement>('#pv-x-axis')
    if (!wrapEl || !svg || !tip) throw new Error('pv-chart: elements not found')

    // --- server data ---
    const J = JSON.parse(wrapEl.dataset.chart!)
    let pvAll: number[] = J.pv
    let loadAll: number[] = J.load
    let battAll: number[] = J.batt
    let gridAll: number[] = J.grid
    let times: number[] = J.times // minuteOfDay per point
    let scaleMin: number = J.scaleMin
    let scaleMax: number = J.scaleMax
    let hasNeg: boolean = J.hasNeg
    let tickNorms: number[] = J.tickNorms
    const isToday: boolean = J.isToday

    const nm = (v: number) => (v - scaleMin) / (scaleMax - scaleMin)

    // --- bezier path — x positioned by actual minuteOfDay ---
    const clamp01 = (x: number) => Math.max(0, Math.min(1, x))
    function smoothLine(values: number[], xMin: number, yMin: number, xMax: number, yMax: number): string {
      if (values.length < 2) return ''
      const tension = 0.9
      const pts = values.map((v, i) => ({
        x: xMin + (times[i] / 1439) * (xMax - xMin),
        y: yMin + (1 - clamp01(v)) * (yMax - yMin),
      }))
      const slopes = pts.slice(0, -1).map((p, i) => (pts[i + 1].y - p.y) / (pts[i + 1].x - p.x))
      const tg = pts.map((_, i) => {
        if (i === 0) return slopes[0]
        if (i === pts.length - 1) return slopes[slopes.length - 1]
        const pr = slopes[i - 1],
          nx = slopes[i]
        if (pr === 0 || nx === 0 || Math.sign(pr) !== Math.sign(nx)) return 0
        return (2 * pr * nx) / (pr + nx)
      })
      slopes.forEach((s, i) => {
        if (s === 0) {
          tg[i] = 0
          tg[i + 1] = 0
          return
        }
        const a = tg[i] / s,
          b = tg[i + 1] / s,
          hy = Math.hypot(a, b)
        if (hy > 3) {
          const sc = 3 / hy
          tg[i] = sc * a * s
          tg[i + 1] = sc * b * s
        }
      })
      let d = `M ${pts[0].x.toFixed(1)},${pts[0].y.toFixed(1)}`
      for (let i = 1; i < pts.length; i++) {
        const p1 = pts[i - 1],
          p2 = pts[i],
          dx = (p2.x - p1.x) / 3
        d += ` C ${(p1.x + dx * tension).toFixed(1)},${(p1.y + tg[i - 1] * dx * tension).toFixed(1)} ${(p2.x - dx * tension).toFixed(1)},${(p2.y - tg[i] * dx * tension).toFixed(1)} ${p2.x.toFixed(1)},${p2.y.toFixed(1)}`
      }
      return d
    }

    // --- state updated on each draw ---
    let curPx0 = 0,
      curPx1 = 0,
      curW = 0
    let crosshair: SVGLineElement | null = null

    function draw() {
      const w = wrapEl!.clientWidth
      const h = wrapEl!.clientHeight
      curW = w
      const [ML, MT, MR, MB] = [4, 18, 8, 28]
      const px0 = ML,
        py0 = MT,
        px1 = w - MR,
        py1 = h - MB
      const ph = py1 - py0
      curPx0 = px0
      curPx1 = px1

      svg!.setAttribute('viewBox', `0 0 ${w} ${h}`)

      const N = pvAll.length
      const lastX = N <= 1 ? px0 : px0 + (times[N - 1] / 1439) * (px1 - px0)

      const pvL = smoothLine(pvAll.map(nm), px0, py0, px1, py1)
      const ldL = smoothLine(loadAll.map(nm), px0, py0, px1, py1)
      const btL = smoothLine(battAll.map(nm), px0, py0, px1, py1)
      const grL = smoothLine(gridAll.map(nm), px0, py0, px1, py1)

      const zeroY = (py0 + (1 - nm(0)) * ph).toFixed(1)
      const gridYs = tickNorms.map((nv) => (py0 + (1 - nv) * ph).toFixed(1))

      svg!.innerHTML = `
        <defs>
          <linearGradient id="pv-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--chart-2)" stop-opacity="0.35"/>
            <stop offset="100%" stop-color="var(--chart-2)" stop-opacity="0"/>
          </linearGradient>
          <linearGradient id="load-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="var(--destructive)" stop-opacity="0.2"/>
            <stop offset="100%" stop-color="var(--destructive)" stop-opacity="0"/>
          </linearGradient>
          <clipPath id="pv-clip"><rect x="${px0}" y="${py0}" width="${px1 - px0}" height="${ph}"/></clipPath>
        </defs>
        <line x1="${px0}" x2="${px1}" y1="${py1}" y2="${py1}" stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"/>
        ${gridYs.map((y) => `<line x1="${px0}" x2="${px1}" y1="${y}" y2="${y}" stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5" stroke-dasharray="2 4"/>`).join('')}
        ${hasNeg ? `<line x1="${px0}" x2="${px1}" y1="${zeroY}" y2="${zeroY}" stroke="var(--border)" stroke-opacity="0.7" stroke-width="0.8"/>` : ''}
        <g clip-path="url(#pv-clip)">
          <path d="${pvL} L ${lastX},${py1} L ${px0},${py1} Z" fill="url(#pv-grad)"/>
          <path d="${pvL}" fill="none" stroke="var(--chart-2)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="${ldL} L ${lastX},${py1} L ${px0},${py1} Z" fill="url(#load-grad)"/>
          <path d="${ldL}" fill="none" stroke="var(--destructive)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="${btL}" fill="none" stroke="var(--chart-3)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="${grL}" fill="none" stroke="var(--chart-4)" stroke-width="0.75" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="5 2" stroke-opacity="0.7"/>
        </g>
        <line class="pv-crosshair" x1="0" x2="0" y1="${py0}" y2="${py1}" stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"/>
        <rect class="pv-overlay" x="${px0}" y="${py0}" width="${px1 - px0}" height="${ph}" fill="transparent" style="cursor:crosshair"/>`

      crosshair = svg!.querySelector('.pv-crosshair')

      if (xAxis) {
        xAxis.style.paddingLeft = ((ML / w) * 100).toFixed(2) + '%'
        xAxis.style.paddingRight = ((MR / w) * 100).toFixed(2) + '%'
      }
    }

    // --- ResizeObserver + 150ms debounce ---
    let t: ReturnType<typeof setTimeout>
    const ro = new ResizeObserver(() => {
      clearTimeout(t)
      t = setTimeout(draw, 150)
    })
    ro.observe(wrapEl!)
    draw()

    // --- tooltip ---
    const fmtBatt = (v: number) => (v > 0.05 ? `+${v.toFixed(2)} kW` : v < -0.05 ? `−${Math.abs(v).toFixed(2)} kW` : '0.00 kW')

    svg!.addEventListener('mousemove', (e) => {
      if (!crosshair) return
      const r = svg!.getBoundingClientRect()
      const sx = ((e.clientX - r.left) / r.width) * curW
      if (sx < curPx0 || sx > curPx1) {
        tip!.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
        return
      }
      const targetMin = ((sx - curPx0) / (curPx1 - curPx0)) * 1439
      const idx = times.reduce((best, t, i) => (Math.abs(t - targetMin) < Math.abs(times[best] - targetMin) ? i : best), 0)
      const cx = (curPx0 + (times[idx] / 1439) * (curPx1 - curPx0)).toFixed(1)
      crosshair.setAttribute('x1', cx)
      crosshair.setAttribute('x2', cx)
      crosshair.setAttribute('visibility', 'visible')
      const totalMin = times[idx]
      tip!.querySelector('.pv-tip-hour')!.textContent = `${String(Math.floor(totalMin / 60)).padStart(2, '0')}:${String(totalMin % 60).padStart(2, '0')} น.`
      tip!.querySelector('.pv-tip-pv')!.textContent = pvAll[idx].toFixed(2) + ' kW'
      tip!.querySelector('.pv-tip-load')!.textContent = loadAll[idx].toFixed(2) + ' kW'
      tip!.querySelector('.pv-tip-batt')!.textContent = fmtBatt(battAll[idx])
      tip!.querySelector('.pv-tip-grid')!.textContent = gridAll[idx] < -0.01 ? Math.abs(gridAll[idx]).toFixed(2) + ' kW' : 'ไม่ซื้อ'
      tip!.classList.remove('hidden')
      tip!.style.left = Math.min(e.clientX + 14, window.innerWidth - 180) + 'px'
      tip!.style.top = Math.max(e.clientY - 90, 8) + 'px'
    })
    svg!.addEventListener('mouseleave', () => {
      tip!.classList.add('hidden')
      crosshair?.setAttribute('visibility', 'hidden')
    })

    // --- realtime poll (today only) ---
    function numFmt(v: number, d: number) {
      return v.toFixed(d)
    }
    function updateYAxis(newGridPct: number[], newYLabels: string[]) {
      const yAxisEl = document.getElementById('pv-y-axis')
      if (!yAxisEl) return
      yAxisEl.innerHTML = newYLabels
        .map(
          (l, i) =>
            `<span class="absolute right-0 text-right text-[9px] leading-none ${i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground'}" style="top:${newGridPct[i]}%;transform:translateY(-50%)">${l}</span>`,
        )
        .join('')
    }
    async function refresh() {
      try {
        const r = await fetch('/api/solar/fivemin')
        if (!r.ok) return
        const d = await r.json()
        pvAll = d.pv
        loadAll = d.load
        battAll = d.batt
        gridAll = d.grid
        times = d.times
        scaleMin = d.scaleMin
        scaleMax = d.scaleMax
        hasNeg = d.hasNeg
        tickNorms = d.tickNorms
        draw()
        updateYAxis(d.gridPct, d.yLabels)
        const ppv = document.getElementById('pv-peak-pv')
        if (ppv) ppv.textContent = numFmt(d.peakPv, 2)
        const pld = document.getElementById('pv-peak-load')
        if (pld) pld.textContent = numFmt(d.peakLoad, 2)
        const pbt = document.getElementById('pv-peak-batt')
        if (pbt) pbt.textContent = numFmt(d.peakBattDis, 2)
      } catch {
        /* network error — skip this tick */
      }
    }
    if (isToday) setInterval(refresh, 60_000)
  }
</script>
