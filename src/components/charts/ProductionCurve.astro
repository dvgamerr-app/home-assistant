---
import { svgLine, svgArea } from '@/lib/chart'
import { num } from '@/lib/electricity'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'

const { hourly: HOURLY } = Astro.props as Pick<SolarData, 'hourly'>
const maxValue = Math.max(...HOURLY.map((h) => Math.max(h.pv, h.load)), 1)
const max = maxValue * 1.12
const peakPv = Math.max(...HOURLY.map((h) => h.pv))
const peakLoad = Math.max(...HOURLY.map((h) => h.load))

const [VW, VH, ML, MT, MR, MB] = [560, 220, 4, 18, 8, 28]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const ph = py1 - py0

// ตัดชั่วโมงอนาคต (ค่า 0) ออก แล้ว scale x ให้ตรงกับ label 24 ชม.
const currentHour = new Date().getHours()
const active = HOURLY.slice(0, Math.min(currentHour + 1, HOURLY.length))
const xEnd = active.length <= 1 ? px0 : px0 + ((active.length - 1) / 23) * (px1 - px0)
const pvVals = active.map((h) => h.pv / max)
const loadVals = active.map((h) => h.load / max)

const pvLine = svgLine(pvVals, px0, py0, xEnd, py1)
const pvFill = svgArea(pvVals, px0, py0, xEnd, py1)
const loadLine = svgLine(loadVals, px0, py0, xEnd, py1)
const loadFill = svgArea(loadVals, px0, py0, xEnd, py1)

const yTicks = [1, 0.75, 0.5, 0.25]
const gridYs = yTicks.map((f) => +(py0 + (1 - f) * ph).toFixed(1))
const gridPct = yTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const xLabels = Array.from({ length: 24 }, (_, i) => String(i).padStart(2, '0'))
const yLabels = yTicks.map((f) => num(max * f, 1))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)
---

<ChartCard eyebrow="พลังงาน" title="กราฟกำลังผลิตรายชั่วโมง" class="flex flex-col overflow-hidden">
  <div class="flex items-end gap-8 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พีคโซลาร์</p>
      <p class="font-serif text-4xl font-light leading-none">
        {num(peakPv, 2)}<span class="ml-1 text-base text-muted-foreground">kW</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">พีคโหลด</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-4)">↑ {num(peakLoad, 2)}</p>
    </div>
    <div class="ml-auto space-y-1 text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">ตลอดวัน</p>
      <p class="font-serif text-base text-muted-foreground">00:00 → 23:00</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative h-56 shrink-0 overflow-visible md:h-60" style="width:1.75rem">
      {
        yLabels.map((l, i) => (
          <span
            class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
            style={`top:${gridPct[i]}%;transform:translateY(-50%)`}
          >
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="h-56 w-full md:h-60">
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <defs>
            <linearGradient id="pv-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--chart-2)" stop-opacity="0.35"></stop>
              <stop offset="100%" stop-color="var(--chart-2)" stop-opacity="0"></stop>
            </linearGradient>
            <linearGradient id="load-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--chart-4)" stop-opacity="0.2"></stop>
              <stop offset="100%" stop-color="var(--chart-4)" stop-opacity="0"></stop>
            </linearGradient>
            <clipPath id="pv-clip"><rect x={px0} y={py0} width={px1 - px0} height={ph}></rect></clipPath>
          </defs>
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y, i) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity={i === 0 ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
          <g clip-path="url(#pv-clip)">
            <path d={pvFill} fill="url(#pv-grad)"></path>
            <path d={pvLine} fill="none" stroke="var(--chart-2)" stroke-width="1.5" stroke-linecap={'round' as const} stroke-linejoin={'round' as const}></path>
            <path d={loadFill} fill="url(#load-grad)"></path>
            <path d={loadLine} fill="none" stroke="var(--chart-4)" stroke-width="1.5" stroke-linecap={'round' as const} stroke-linejoin={'round' as const}></path>
          </g>
          <line class="pv-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
          <rect
            class="pv-overlay"
            x={px0}
            y={py0}
            width={px1 - px0}
            height={ph}
            fill="transparent"
            style="cursor:crosshair"
            data-px0={px0}
            data-px1={px1}
            data-vw={VW}
            data-pv={JSON.stringify(HOURLY.map((h) => h.pv))}
            data-load={JSON.stringify(HOURLY.map((h) => h.load))}></rect>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {xLabels.map((l) => <span>{l}</span>)}
      </div>
    </div>
  </div>

  <LegendRow
    class="mt-3"
    items={[
      { label: 'ผลิตจากแผง (kW)', color: 'var(--chart-2)' },
      { label: 'ใช้ในบ้าน (kW)', color: 'var(--chart-4)' },
    ]}
  />
</ChartCard>

<div class="pv-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:140px">
  <p class="pv-tip-hour mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="space-y-1.5">
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-2)"></span>โซลาร์
      </span>
      <span class="pv-tip-pv font-mono text-[11px] text-foreground"></span>
    </div>
    <div class="flex items-center justify-between gap-4">
      <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
        <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-4)"></span>โหลด
      </span>
      <span class="pv-tip-load font-mono text-[11px] text-foreground"></span>
    </div>
  </div>
</div>

<script>
  {
    const overlay = document.querySelector<SVGRectElement>('.pv-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.pv-crosshair')
    const tip = document.querySelector<HTMLElement>('.pv-chart-tip')
    if (svg && overlay && tip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const pvData: number[] = JSON.parse(d.pv!)
      const loadData: number[] = JSON.parse(d.load!)
      const n = pvData.length
      const hourEl = tip.querySelector('.pv-tip-hour')!
      const pvEl = tip.querySelector('.pv-tip-pv')!
      const loadEl = tip.querySelector('.pv-tip-load')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          tip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = n > 1 ? (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1) : String(px0)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        hourEl.textContent = String(idx).padStart(2, '0') + ':00 น.'
        pvEl.textContent = pvData[idx].toFixed(2) + ' kW'
        loadEl.textContent = loadData[idx].toFixed(2) + ' kW'
        tip.classList.remove('hidden')
        tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 160) + 'px'
        tip.style.top = Math.max(e.clientY - 70, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        tip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
