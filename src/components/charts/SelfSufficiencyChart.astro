---
import { svgLine, svgArea } from '@/lib/chart'
import type { SolarData } from '@/lib/solar-data'
import ChartCard from '@/components/ui/ChartCard.astro'
import LegendRow from '@/components/ui/LegendRow.astro'

const { months: MONTHS } = Astro.props as Pick<SolarData, 'months'>
const data = MONTHS.map((m) => ({
  month: m.month,
  ratio: m.consumed > 0 ? Math.round((m.selfUse / m.consumed) * 100) : 0,
}))
const vals = data.map((d) => d.ratio / 100)

const nonZero = data.filter((d) => d.ratio > 0)
const avgRatio = nonZero.length > 0 ? Math.round(nonZero.reduce((s, d) => s + d.ratio, 0) / nonZero.length) : 0
const bestMonth = nonZero.reduce((b, d) => (d.ratio > b.ratio ? d : b), nonZero[0] ?? { month: '-', ratio: 0 })

const [VW, VH, ML, MT, MR, MB] = [560, 160, 4, 8, 8, 24]
const [px0, py0, px1, py1] = [ML, MT, VW - MR, VH - MB]
const ph = py1 - py0

const linePath = svgLine(vals, px0, py0, px1, py1)
const fillPath = svgArea(vals, px0, py0, px1, py1)
const yTicks = [1, 0.75, 0.5, 0.25]
const gridYs = yTicks.map((f) => +(py0 + (1 - f) * ph).toFixed(1))
const gridPct = yTicks.map((f) => +(((MT + (1 - f) * ph) / VH) * 100).toFixed(2))
const padLeft = +((ML / VW) * 100).toFixed(2)
const padRight = +((MR / VW) * 100).toFixed(2)
const yLabels = ['100%', '75%', '50%', '25%']
---

<ChartCard eyebrow="รายเดือน" title="การพึ่งพาตัวเองรายเดือน" class="flex flex-col overflow-hidden">
  <div class="flex items-end gap-8 border-b border-border/60 pb-5">
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">เฉลี่ย</p>
      <p class="font-serif text-4xl font-light leading-none">
        {avgRatio}<span class="ml-1 text-base text-muted-foreground">%</span>
      </p>
    </div>
    <div class="space-y-1">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">เดือนดีสุด</p>
      <p class="font-serif text-2xl font-light leading-none" style="color:var(--chart-1)">{bestMonth.month}</p>
    </div>
    <div class="ml-auto space-y-1 text-right">
      <p class="text-[10px] uppercase tracking-luxury text-muted-foreground">สูงสุด</p>
      <p class="font-serif text-lg text-foreground">{bestMonth.ratio}%</p>
    </div>
  </div>

  <div class="mt-5 flex items-start gap-1">
    <div class="relative h-40 shrink-0 overflow-visible" style="width:1.75rem">
      {
        yLabels.map((l, i) => (
          <span
            class:list={['absolute right-0 text-right text-[9px] leading-none', i === 0 ? 'font-medium text-foreground/60' : 'text-muted-foreground']}
            style={`top:${gridPct[i]}%;transform:translateY(-50%)`}
          >
            {l}
          </span>
        ))
      }
    </div>
    <div class="min-w-0 flex-1">
      <div class="h-40 w-full">
        <svg viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none" width="100%" height="100%">
          <defs>
            <linearGradient id="self-grad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="var(--chart-1)" stop-opacity="0.35"></stop>
              <stop offset="100%" stop-color="var(--chart-1)" stop-opacity="0"></stop>
            </linearGradient>
            <clipPath id="self-clip"><rect x={px0} y={py0} width={px1 - px0} height={ph}></rect></clipPath>
          </defs>
          <line x1={px0} x2={px1} y1={py1} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          <line x1={px0} x2={px0} y1={py0} y2={py1} stroke="var(--border)" stroke-opacity="0.8" stroke-width="0.5"></line>
          {gridYs.map((y, i) => <line x1={px0} x2={px1} y1={y} y2={y} stroke="var(--border)" stroke-opacity={i === 0 ? '0.4' : '0.8'} stroke-width="0.5" stroke-dasharray="2 4" />)}
          <g clip-path="url(#self-clip)">
            <path d={fillPath} fill="url(#self-grad)"></path>
            <path d={linePath} fill="none" stroke="var(--chart-1)" stroke-width="1.5" stroke-linecap={'round' as const} stroke-linejoin={'round' as const}></path>
          </g>
          <line class="self-crosshair" x1="0" x2="0" y1={py0} y2={py1} stroke="var(--foreground)" stroke-opacity="0.2" stroke-width="0.5" visibility="hidden"></line>
          <rect
            class="self-overlay"
            x={px0}
            y={py0}
            width={px1 - px0}
            height={ph}
            fill="transparent"
            style="cursor:crosshair"
            data-px0={px0}
            data-px1={px1}
            data-vw={VW}
            data-ratios={JSON.stringify(data.map((d) => d.ratio))}
            data-months={JSON.stringify(data.map((d) => d.month))}></rect>
        </svg>
      </div>
      <div class="mt-1 flex justify-between text-[9px] tracking-wider text-muted-foreground" style={`padding-left:${padLeft}%;padding-right:${padRight}%`}>
        {data.map((d) => <span>{d.month}</span>)}
      </div>
    </div>
  </div>

  <LegendRow class="mt-3" items={[{ label: 'พึ่งพาตัวเอง (%)', color: 'var(--chart-1)' }]} />
</ChartCard>

<div class="self-chart-tip pointer-events-none fixed z-50 hidden rounded-lg border border-border/70 bg-card px-3 py-2.5 shadow-md" style="min-width:130px">
  <p class="self-tip-month mb-2 text-[10px] uppercase tracking-luxury text-muted-foreground"></p>
  <div class="flex items-center justify-between gap-4">
    <span class="flex items-center gap-1.5 text-[11px] text-muted-foreground">
      <span class="h-2 w-2 shrink-0 rounded-full" style="background:var(--chart-1)"></span>พึ่งตัวเอง
    </span>
    <span class="self-tip-val font-mono text-[11px] font-medium text-foreground"></span>
  </div>
</div>

<script>
  {
    const overlay = document.querySelector<SVGRectElement>('.self-overlay')
    const svg = overlay?.closest('svg') as SVGSVGElement | null
    const crosshair = document.querySelector<SVGLineElement>('.self-crosshair')
    const tip = document.querySelector<HTMLElement>('.self-chart-tip')
    if (svg && overlay && tip && crosshair) {
      const d = overlay.dataset
      const px0 = +d.px0!,
        px1 = +d.px1!,
        vw = +d.vw!
      const ratios: number[] = JSON.parse(d.ratios!)
      const months: string[] = JSON.parse(d.months!)
      const n = ratios.length
      const monthEl = tip.querySelector('.self-tip-month')!
      const valEl = tip.querySelector('.self-tip-val')!

      svg.addEventListener('mousemove', (e) => {
        const r = svg.getBoundingClientRect()
        const sx = ((e.clientX - r.left) / r.width) * vw
        if (sx < px0 || sx > px1) {
          tip.classList.add('hidden')
          crosshair.setAttribute('visibility', 'hidden')
          return
        }
        const idx = Math.max(0, Math.min(n - 1, Math.round(((sx - px0) / (px1 - px0)) * (n - 1))))
        const cx = n > 1 ? (px0 + (idx / (n - 1)) * (px1 - px0)).toFixed(1) : String(px0)
        crosshair.setAttribute('x1', cx)
        crosshair.setAttribute('x2', cx)
        crosshair.setAttribute('visibility', 'visible')
        monthEl.textContent = months[idx]
        valEl.textContent = ratios[idx] + '%'
        tip.classList.remove('hidden')
        tip.style.left = Math.min(e.clientX + 14, window.innerWidth - 160) + 'px'
        tip.style.top = Math.max(e.clientY - 70, 8) + 'px'
      })
      svg.addEventListener('mouseleave', () => {
        tip.classList.add('hidden')
        crosshair.setAttribute('visibility', 'hidden')
      })
    }
  }
</script>
