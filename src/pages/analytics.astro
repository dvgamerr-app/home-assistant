---
import Layout from '@/layouts/Layout.astro'
import Nav from '@/components/Nav.astro'
import BatteryCard from '@/components/BatteryCard.astro'
import SystemHealth from '@/components/SystemHealth.astro'
import PanelStrings from '@/components/PanelStrings.astro'
import EnergyDistributionChart from '@/components/EnergyDistributionChart.astro'
import ProductionCurve from '@/components/ProductionCurve.astro'
import BatterySocChart from '@/components/BatterySocChart.astro'
import SelfSufficiencyChart from '@/components/SelfSufficiencyChart.astro'
---

<Layout title="วิเคราะห์เชิงลึก">
  <Nav />
  <main class="mx-auto max-w-6xl space-y-8 px-6 py-10 md:px-10 md:py-12">
    <header class="space-y-3">
      <p class="text-[11px] uppercase tracking-luxury text-muted-foreground">วิเคราะห์เชิงลึก</p>
      <h1 class="font-serif text-4xl font-light leading-tight text-foreground md:text-5xl">ข้อมูลเชิงลึกของระบบ</h1>
      <p class="max-w-md text-pretty text-sm leading-relaxed text-muted-foreground">เจาะลึกแบตเตอรี่ แผงโซลาร์ สุขภาพอินเวอร์เตอร์ และพฤติกรรมการใช้พลังงานตลอดทั้งวันและทั้งปี</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-2">
      <BatteryCard />
      <SystemHealth />
      <PanelStrings />
      <EnergyDistributionChart />
    </div>

    <ProductionCurve />

    <div class="grid gap-6 lg:grid-cols-2">
      <BatterySocChart />
      <SelfSufficiencyChart />
    </div>
  </main>
</Layout>
