---
import Layout from '@/layouts/Layout.astro'
import Nav from '@/components/Nav.astro'
import ElectricityNav from '@/components/ElectricityNav.astro'
import DailyView from '@/components/DailyView.astro'
import { getAll, getMonthLoad } from '@/lib/solar-data'

const now = new Date()
const curYear = now.getFullYear()
const curMonth = now.getMonth() + 1

const mParam = Astro.url.searchParams.get('m')
let selYear = curYear,
  selMonth = curMonth
if (mParam && /^\d{6}$/.test(mParam)) {
  selYear = parseInt(mParam.slice(0, 4))
  selMonth = Math.max(1, Math.min(12, parseInt(mParam.slice(4, 6))))
}
const isCurrentMonth = selYear === curYear && selMonth === curMonth
const selectedMonthStr = `${selYear}${String(selMonth).padStart(2, '0')}`

// prev month of selected
const prevDate = new Date(selYear, selMonth - 2, 1)
const prevYear = prevDate.getFullYear()
const prevMonth = prevDate.getMonth() + 1

const [data, selMonthData, prevMonthData] = await Promise.all([getAll(), isCurrentMonth ? Promise.resolve(null) : getMonthLoad(selYear, selMonth), getMonthLoad(prevYear, prevMonth)])

// เดือนที่มีข้อมูลจริงใน DB (จาก getMonths(12) ใน getAll)
const availableMonths = data.monthPicker

const monthDays = isCurrentMonth ? data.monthDays : selMonthData!.days
const monthLabel = isCurrentMonth ? data.monthLabel : selMonthData!.label
---

<Layout title="การใช้ไฟในบ้าน — บ้าน">
  <Nav />
  <main class="space-y-8 px-6 py-10 md:px-10 md:py-12">
    <header class="space-y-3">
      <p class="text-[11px] uppercase tracking-luxury text-muted-foreground">ระบบไฟฟ้า</p>
      <h1 class="font-serif text-4xl font-light leading-tight text-foreground md:text-5xl">ข้อมูลพลังงาน</h1>
    </header>

    <ElectricityNav active="load" />

    <DailyView
      today={data.today}
      day={data.day}
      monthDays={monthDays}
      monthLabel={monthLabel}
      isCurrentMonth={isCurrentMonth}
      selMonthTotals={selMonthData?.totals}
      prevMonthSummary={prevMonthData}
      availableMonths={availableMonths}
      selectedMonth={selectedMonthStr}
    />
  </main>
</Layout>
