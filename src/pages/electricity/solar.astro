---
import Layout from '@/layouts/Layout.astro'
import Nav from '@/components/Nav.astro'
import ElectricityNav from '@/components/ElectricityNav.astro'
import SolarStatusCards from '@/components/SolarStatusCards.svelte'
import EnergyDistributionChart from '@/components/charts/EnergyDistributionChart.astro'
import ProductionCurve from '@/components/charts/ProductionCurve.astro'
import SolarProductionRateCurve from '@/components/charts/SolarProductionRateCurve.astro'
import SelfSufficiencyChart from '@/components/charts/SelfSufficiencyChart.astro'
import { getBangkokISODate, isISODate, parseISODate } from '@/lib/date'
import { getAll } from '@/lib/solar-data'

const dateParam = Astro.url.searchParams.get('date')
const todayISO = getBangkokISODate()
const selectedISO = isISODate(dateParam) ? dateParam : todayISO
const selectedDate = parseISODate(selectedISO)
const isToday = selectedISO === todayISO
const data = await getAll(selectedDate)

const { protocol, hostname } = Astro.url
const socketUrl = `${protocol}//${hostname}:${process.env.SOCKET_PORT ?? '3000'}`
---

<Layout title="ผลิตไฟ — บ้าน">
  <Nav />
  <main class="space-y-8 px-6 py-10 md:px-10 md:py-12">
    <header class="space-y-3">
      <p class="text-[11px] uppercase tracking-luxury text-muted-foreground">ระบบไฟฟ้า</p>
      <h1 class="font-serif text-4xl font-light leading-tight text-foreground md:text-5xl">ข้อมูลพลังงาน</h1>
    </header>

    <ElectricityNav active="solar" />

    <div class="space-y-6">
      <!-- main chart — full width -->
      <ProductionCurve fiveMin={data.fiveMin} date={selectedISO} isToday={isToday} socketUrl={socketUrl} />

      <!-- status cards — realtime via socket.io -->
      <SolarStatusCards live={data.live} pvStrings={data.pvStrings} system={data.system} socketUrl={socketUrl} client:load />
      <div class="pt-2 md:pt-4">
        <SolarProductionRateCurve fiveMin={data.fiveMin} isToday={isToday} ratedPowerKw={data.system.ratedPowerKw} socketUrl={socketUrl} />
      </div>

      <!-- analysis -->
      <div class="grid gap-6 lg:grid-cols-2">
        <SelfSufficiencyChart months={data.months} />
        <EnergyDistributionChart energyDistribution={data.energyDistribution} />
      </div>
    </div>
  </main>
</Layout>
