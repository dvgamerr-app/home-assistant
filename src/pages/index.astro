---
import Layout from '@/layouts/Layout.astro'
import Nav from '@/components/Nav.astro'
import Hero from '@/components/Hero.astro'
import PaybackCard from '@/components/PaybackCard.astro'
import EnergyFlow from '@/components/EnergyFlow.svelte'
import StatCard from '@/components/StatCard.astro'
import Sun from '@lucide/svelte/icons/sun'
import Plug from '@lucide/svelte/icons/plug'
import PiggyBank from '@lucide/svelte/icons/piggy-bank'
import Gauge from '@lucide/svelte/icons/gauge'
import { getAll } from '@/lib/solar-data'
import { thb, num } from '@/lib/electricity'

const data = await getAll()
const { protocol, hostname } = new URL(Astro.request.url)
const socketUrl = `${protocol}//${hostname}:${process.env.SOCKET_PORT ?? '3000'}`
---

<Layout title="ภาพรวมพลังงานในบ้าน">
  <Nav />
  <Hero live={data.live} system={data.system} />
  <main class="space-y-8 px-6 py-10 md:px-10 md:py-12">
    <div class="grid items-stretch gap-4 lg:grid-cols-3">
      <div class="flex flex-col gap-4 lg:col-span-2">
        <section class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <StatCard
              label="ผลิตไฟวันนี้"
              value={`${num(data.today.generated, 1)} kWh`}
              sub={`ผลิตมาแล้ว ${num(data.today.generationHours, 1)} ชม.`}
              trend={`${num(data.day.selfSufficiency, 0)}% พึ่งตัวเอง`}
              accent="brass"
            >
              <Sun slot="icon" size={18} strokeWidth={1.25} />
            </StatCard>
            <StatCard label="ใช้ไฟวันนี้" value={`${num(data.today.consumed, 1)} kWh`} sub={`ใช้จากแสงอาทิตย์ ${num(data.day.selfUse, 1)} kWh`} accent="blue">
              <Plug slot="icon" size={18} strokeWidth={1.25} />
            </StatCard>
            <StatCard label="ประหยัดวันนี้" value={thb(data.day.savedTHB, 0)} sub={`ถ้าไม่มีโซลาร์จ่าย ${thb(data.day.wouldHaveCostTHB, 0)}`} accent="sage">
              <PiggyBank slot="icon" size={18} strokeWidth={1.25} />
            </StatCard>
            <StatCard label="ค่าไฟจากกริดวันนี้" value={thb(data.day.gridCostTHB, 0)} sub={`ซื้อจากการไฟฟ้า ${num(data.today.gridImport, 1)} kWh`} accent="terracotta">
              <Gauge slot="icon" size={18} strokeWidth={1.25} />
            </StatCard>
          </div>
        </section>
        <PaybackCard system={data.system} payback={data.payback} />
      </div>
      <div class="lg:col-span-1">
        <EnergyFlow live={data.live} socketUrl={socketUrl} client:load />
      </div>
    </div>

    <p class="text-pretty pb-4 text-center text-xs leading-relaxed text-muted-foreground">
      ค่าไฟคำนวณตามอัตราค่าไฟฟ้าบ้านอยู่อาศัย ประเภท 1.2 แบบขั้นบันไดของการไฟฟ้านครหลวง (MEA) รวมค่า Ft และภาษีมูลค่าเพิ่ม 7%
    </p>
  </main>
</Layout>
